{
  "$schema": "https://turbo.build/json-schema.json",
  "globalDependencies": [
    ".env",
    ".env.local",
    ".env.*.local"
  ],
  "globalEnv": [
    "NODE_ENV"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "outputs": [
        "dist/**",
        ".next/**",
        "build/**"
      ],
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {
      "outputs": [],
      "cache": false
    },
    "type-check": {
      "outputs": [],
      "cache": false
    },
    "test": {
      "outputs": [
        "coverage/**"
      ],
      "cache": false
    },
    "db:push": {
      "cache": false,
      "inputs": [
        "prisma/schema.prisma"
      ]
    },
    "db:migrate": {
      "cache": false,
      "inputs": [
        "prisma/migrations/**"
      ]
    }
  }
}
