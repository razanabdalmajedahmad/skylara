# ============================================================================
# DATABASE
# ============================================================================
# Append ?connection_limit=N&pool_timeout=N for production pool tuning
# Recommended: connection_limit = (num_cpu * 2) + 1, pool_timeout = 10
DATABASE_URL="mysql://root:UYGUvNfBoyrlCBCoimzrVdCCGWbBwGjQ@nozomi.proxy.rlwy.net:10411/railway?connection_limit=10&pool_timeout=10"
DATABASE_READ_URL="mysql://root:UYGUvNfBoyrlCBCoimzrVdCCGWbBwGjQ@nozomi.proxy.rlwy.net:10411/railway?connection_limit=10&pool_timeout=10"

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-long15"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="your-refresh-secret-key-min-32-chars-long"
JWT_REFRESH_EXPIRES_IN="7d"
BCRYPT_ROUNDS=12

# OAuth2
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
APPLE_CLIENT_ID="your-apple-client-id"
APPLE_TEAM_ID="your-apple-team-id"
APPLE_KEY_ID="your-apple-key-id"
APPLE_KEY="your-apple-private-key"

# ============================================================================
# STRIPE & PAYMENTS
# ============================================================================
# Use sk_test_ prefix for test mode — Stripe Connect endpoints will use mock
# accounts and payouts automatically when the key starts with "sk_test_".
# Get test keys at: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY="pk_test_xxxxx"
STRIPE_SECRET_KEY="sk_test_xxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxx"
STRIPE_CONNECT_CLIENT_ID="ca_xxxxx"

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
REDIS_DB=0

# ============================================================================
# EMAIL & SMS
# ============================================================================
SENDGRID_API_KEY="SG.xxxxx"
SENDGRID_FROM_EMAIL="noreply@skylara.com"

TWILIO_ACCOUNT_SID="AC_xxxxx"
TWILIO_AUTH_TOKEN="xxxxx"
TWILIO_PHONE_NUMBER="+1234567890"
TWILIO_WHATSAPP_NUMBER="+1234567890"

# Frontend URL (for email links and redirects)
FRONTEND_URL="http://localhost:3000"

# ============================================================================
# PUSH NOTIFICATIONS — Expo (mobile) + VAPID (web browser)
# ============================================================================
# Expo Push abstracts FCM/APNs for iOS & Android — no Firebase SDK needed
EXPO_ACCESS_TOKEN="your-expo-access-token"

# VAPID keys for Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@skylara.com"

# ============================================================================
# STORAGE
# ============================================================================
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="AKIA_xxxxx"
AWS_SECRET_ACCESS_KEY="xxxxx"
S3_BUCKET_NAME="skylara-storage"
S3_CLOUDFRONT_DOMAIN="d123.cloudfront.net"

# ============================================================================
# WEATHER & LOCATION APIS
# ============================================================================
WEATHER_API_KEY="your-weather-api-key"
MAPBOX_API_TOKEN="pk_xxxxx"
GOOGLE_MAPS_API_KEY="AIzaSy_xxxxx"

# ============================================================================
# EXTERNAL INTEGRATIONS
# ============================================================================
USPA_API_KEY="xxxxx"
USPA_API_URL="https://api.uspa.org"
FAA_API_URL="https://api.faa.gov"

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
NODE_ENV="development"
APP_NAME="SkyLara"
APP_VERSION="0.1.0"
LOG_LEVEL="info"
CORS_ORIGIN="http://localhost:3000"

# API Settings
API_HOST="localhost"
API_PORT=3001
API_BASE_URL="http://localhost:3001/api"

# Web Settings
WEB_HOST="localhost"
WEB_PORT=3000
WEB_BASE_URL="http://localhost:3000"

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================
SENTRY_DSN="https://xxxxx@sentry.io/project-id"
SENTRY_ENVIRONMENT="development"
DATADOG_API_KEY="xxxxx"
DATADOG_APP_KEY="xxxxx"

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_STRIPE_PAYMENTS=true
FEATURE_OFFLINE_SYNC=true
FEATURE_MULTI_DZ=false
FEATURE_ANALYTICS=true
FEATURE_AI_INSIGHTS=false
FEATURE_MOBILE_APP=false

# ============================================================================
# ADMIN & DEVELOPMENT
# ============================================================================
ADMIN_SECRET_KEY="admin-secret-for-internal-endpoints"
ALLOW_SEED_DATA=true
ENABLE_PLAYGROUND=true
ENABLE_INTROSPECTION=true
