{
  "expo": {
    "name": "SkyLara",
    "slug": "skylara",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "skylara",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.skylara.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SkyLara needs camera access to scan QR codes for jumper check-in",
        "NSLocationWhenInUseUsageDescription": "SkyLara uses your location to verify dropzone check-in"
      }
    },
    "android": {
      "package": "com.skylara.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png"
        }
      ],
      "expo-local-authentication"
    ]
  }
}
