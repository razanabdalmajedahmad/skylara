{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@repo/types": [
        "../../packages/types/src"
      ],
      "@repo/types/*": [
        "../../packages/types/src/*"
      ],
      "@repo/config": [
        "../../packages/config/src"
      ],
      "@repo/config/*": [
        "../../packages/config/src/*"
      ],
      "@repo/ui": [
        "../../packages/ui/src"
      ],
      "@repo/ui/*": [
        "../../packages/ui/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "nativewind-env.d.ts",
    "src/types/shims.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}