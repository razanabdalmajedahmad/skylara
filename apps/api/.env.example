# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Database
DATABASE_URL=mysql://root:root@localhost:3306/skylara

# JWT (RS256 in production, HS256 fallback in dev)
JWT_SECRET=skylara-dev-jwt-secret-key-change-in-production-min-32-chars
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN RSA PUBLIC KEY-----\n...\n-----END RSA PUBLIC KEY-----
BCRYPT_ROUNDS=12

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Stripe (optional)
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# WebAuthn (optional)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Redis (optional — caching, rate limiting)
# REDIS_URL=redis://localhost:6379

# AWS S3 (optional — file uploads)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=skylara-storage

# SendGrid (optional — email delivery)
# SENDGRID_API_KEY=SG.xxxxx
# SENDGRID_FROM_EMAIL=noreply@skylara.com

# Twilio (optional — SMS / WhatsApp)
# TWILIO_ACCOUNT_SID=AC_xxxxx
# TWILIO_AUTH_TOKEN=xxxxx
# TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_WHATSAPP_NUMBER=+1234567890

# Push — Expo (mobile, abstracts FCM/APNs)
# EXPO_ACCESS_TOKEN=your-expo-access-token

# Push — Web VAPID (browser push, generate: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@skylara.com

# Weather API (optional — Open-Meteo is free, no key needed)
# WEATHER_API_KEY=
# WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# Sentry (optional — error tracking)
# SENTRY_DSN=https://xxxxx@sentry.io/project-id
