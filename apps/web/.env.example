# SkyLara Web — copy to .env.local (never commit secrets)
# See docs/SkyLara_Developer_Environment.md

# API (public — browser-visible only)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Optional: alternate name used in some hooks
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# WebSocket base (no path — client appends channels)
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Set to "true" only when a real analytics integration is configured (Phase 7+)
# NEXT_PUBLIC_ANALYTICS_ENABLED=false
