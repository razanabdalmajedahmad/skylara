{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@repo/types": [
        "packages/types/src"
      ],
      "@repo/types/*": [
        "packages/types/src/*"
      ],
      "@repo/config": [
        "packages/config/src"
      ],
      "@repo/config/*": [
        "packages/config/src/*"
      ],
      "@repo/ui": [
        "packages/ui/src"
      ],
      "@repo/ui/*": [
        "packages/ui/src/*"
      ],
      "@/*": [
        "apps/web/src/*"
      ],
      "@api/*": [
        "apps/api/src/*"
      ]
    },
    "types": [
      "node"
    ]
  }
}
