  learningQuizAttempts      LearningQuizAttempt[] @relation("LearningQuizAttemptUser")
  learningCertificates      LearningCertificate[] @relation("LearningCertUser")
  learningCertificatesIssued LearningCertificate[] @relation("LearningCertIssuer")
  learningAchievements      LearningAchievement[] @relation("LearningAchievementUser")
  learningSubscriptions     LearningSubscription[] @relation("LearningSubUser")
  learningEventAttendance   LearningEventAttendance[] @relation("LearningAttendanceUser")
  learningEventVerifications LearningEventAttendance[] @relation("LearningAttendanceVerifier")
  learningSavedContent      LearningSavedContent[] @relation("LearningSavedUser")
  learningRecommendations   LearningRecommendation[] @relation("LearningRecUser")
  // Data Management relations
  dataOperations            DataOperation[]
  // Gift Card relations
  giftCardsIssued           GiftCard[] @relation("GiftCardIssuer")
  giftCardsRedeemed         GiftCard[] @relation("GiftCardRedeemer")
  // Platform Phase 2 relations
  impersonationsAsActor     ImpersonationSession[] @relation("ImpersonationActor")
  impersonationsAsTarget    ImpersonationSession[] @relation("ImpersonationTarget")
  walletTransfersInitiated  WalletTransfer[] @relation("TransferInitiator")
  walletTransfersApproved   WalletTransfer[] @relation("TransferApprover")
  facilityReviews           FacilityReview[] @relation("FacilityReviewAuthor")
  facilityReviewResponses   FacilityReview[] @relation("FacilityReviewResponder")
  orgAssistantPromptTemplateChanges OrganizationAssistantPromptTemplateChange[] @relation("OrgAssistantPromptTemplateChangeActor")
  venueSpacesCreated              VenueSpace[] @relation("VenueSpaceCreatedBy")
  venueBookingsCreated            VenueBooking[] @relation("VenueBookingCreatedBy")
  venueBookingsRequested          VenueBooking[] @relation("VenueBookingRequester")
  venueBookingsReviewed           VenueBooking[] @relation("VenueBookingReviewedBy")

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model UserProfile {
  id                      Int       @id @default(autoincrement())
  userId                  Int       @unique
  avatar                  String?   @db.Text
  bio                     String?   @db.Text
  dateOfBirth             DateTime?
  gender                  String?   @db.VarChar(50)
  nationality             String?   @db.VarChar(100)
  emergencyContactName    String?   @db.VarChar(100)
  emergencyContactPhone   String?   @db.VarChar(20)
  emergencyContactRelation String?  @db.VarChar(50)
  notificationPreferences Json      @default("{}")
  visibilityPublic        Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relations
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Role {
  id              Int       @id @default(autoincrement())
  name            String    @unique @db.VarChar(100)
  displayName     String    @db.VarChar(100)
  description     String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  userRoles       UserRole[]

  @@map("roles")
}

model UserRole {
  id              Int       @id @default(autoincrement())
  userId          Int
  roleId          Int
  organizationId  Int?
  dropzoneId      Int?
  grantedBy       Int?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  dropzone        Dropzone? @relation(fields: [dropzoneId], references: [id], onDelete: SetNull)

  @@unique([userId, roleId, organizationId, dropzoneId])
  @@index([userId])
  @@index([roleId])
  @@index([dropzoneId])
  @@map("user_roles")
}

model RefreshToken {
  id              Int       @id @default(autoincrement())
  token           String    @unique @db.VarChar(512)
  userId          Int
  expiresAt       DateTime
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id              Int       @id @default(autoincrement())
  token           String    @unique @db.VarChar(255)
  userId          Int
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

model Organization {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @db.VarChar(36)
  name            String    @db.VarChar(255)
  slug            String    @unique @db.VarChar(100)
  ownerId         Int       @unique
  subscriptionTier String   @default("starter") @db.VarChar(50)
  /// Optional registry template id for portal assistant (e.g. portal_assistant@2026-04-13.v3). Null = use env / default.
  assistantPromptTemplateId String? @db.VarChar(120)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  owner           User      @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  dropzones       Dropzone[]
  userRoles       UserRole[]
  // Onboarding center relations
  onboardingTemplates       OnboardingTemplate[]
  onboardingApplications    OnboardingApplication[]
  approvalRules             ApprovalRule[]
  notificationCampaigns     NotificationCampaign[]
  segments                  Segment[]
  automationRules           AutomationRule[]
  assistantRecommendations  AssistantRecommendation[]
  jobPosts                  JobPost[] @relation("JobPostOrg")
  // Learning & Subscriptions
  learningCourses           LearningCourse[] @relation("OrgLearningCourses")
  // Data Management
  dataOperations            DataOperation[]
  // Global Platform Hierarchy
  facilities                Facility[]
  /// Phase 25: append-only history of assistant prompt template pins (no prompt bodies).
  assistantPromptTemplateChanges OrganizationAssistantPromptTemplateChange[]
  /// Phase 26: optional staged template experiment when org pin is unset.
  assistantPromptExperiment OrganizationAssistantPromptExperiment?

  @@index([ownerId])
  @@map("organizations")
}

/// Durable audit trail for `Organization.assistantPromptTemplateId` changes (org-scoped; no dropzone required).
model OrganizationAssistantPromptTemplateChange {
  id                        Int      @id @default(autoincrement())
  organizationId            Int
  previousTemplateId        String?  @db.VarChar(120)
  newTemplateId             String?  @db.VarChar(120)
  actorUserId               Int?
  actorRoleSummary          String?  @db.VarChar(256)
  changeSource              String   @default("dashboard_put") @db.VarChar(64)
  /// Effective resolution source immediately after this change (org vs env vs default).
  effectiveSelectionSource  String?  @db.VarChar(40)
  createdAt                 DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation("OrgAssistantPromptTemplateChangeActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("organization_assistant_prompt_template_changes")
}

/// Phase 26: org-scoped staged assistant prompt template experiment (registry id only; no prompt bodies).
model OrganizationAssistantPromptExperiment {
  id                   Int      @id @default(autoincrement())
  organizationId       Int      @unique
  enabled              Boolean  @default(false)
  experimentTemplateId String   @db.VarChar(120)
  /// JSON string[] of `Organization.subscriptionTier` values; null or [] = all tiers.
  cohortTiers          Json?
  /// 0–100; deterministic user inclusion via stable hash(userId, organizationId).
  rolloutPercent       Int      @default(100)
  /// Short id for logs/metrics (e.g. v4_preview); optional.
  experimentKey        String?  @db.VarChar(64)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_assistant_prompt_experiments")
