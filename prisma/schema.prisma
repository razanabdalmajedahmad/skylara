  jumpabilityScore Int?     // 0-100
  weatherStatus   String?   @db.VarChar(10) // VFR, MVFR, IFR, LIFR
  fetchedAt       DateTime  @default(now())

  dropzone        Dropzone  @relation("WeatherDz", fields: [dropzoneId], references: [id], onDelete: Cascade)

