// ============================================================================
// ONBOARDING CENTER — Templates, Applications, Steps
// ============================================================================

model OnboardingTemplate {
  id                Int                   @id @default(autoincrement())
  uuid              String                @unique @db.VarChar(36)
  orgId             Int?
  dropzoneId        Int?
  category          OnboardingCategory
  name              String                @db.VarChar(255)
  description       String?               @db.Text
  flowKey           String                @db.VarChar(100) // e.g. "visiting-jumper", "coach-application"
  internalRoute     String?               @db.VarChar(255) // /app/onboarding/visiting-jumper
  externalSlug      String?               @db.VarChar(100) // join/skyhigh/visiting-jumper
  accessMode        OnboardingAccessMode  @default(PUBLIC)
  requireLogin      Boolean               @default(false)
  allowGuestMode    Boolean               @default(true)
  allowSaveResume   Boolean               @default(true)
  tokenExpiryHours  Int?
  status            String                @default("ACTIVE") @db.VarChar(20)
  version           Int                   @default(1)
  configJson        Json                  @default("{}")
  eligibilityRules  Json                  @default("[]") // rules for smart routing
  postSubmitAction  String?               @db.VarChar(50) // redirect, message, auto-approve
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  steps             OnboardingTemplateStep[]
  applications      OnboardingApplication[]
  approvalRules     ApprovalRule[]
  organization      Organization?         @relation(fields: [orgId], references: [id], onDelete: SetNull)
  dropzone          Dropzone?             @relation(fields: [dropzoneId], references: [id], onDelete: SetNull)

  @@unique([dropzoneId, flowKey])
  @@index([category])
  @@index([status])
  @@index([externalSlug])
  @@map("onboarding_templates")
}

model OnboardingTemplateStep {
  id                Int                   @id @default(autoincrement())
  templateId        Int
  key               String                @db.VarChar(100) // e.g. "personal-info", "license-upload"
  label             String                @db.VarChar(255)
  description       String?               @db.Text
  type              OnboardingStepType
  orderIndex        Int
  required          Boolean               @default(true)
  conditionRules    Json                  @default("[]") // show/skip rules based on profile
  fieldsConfig      Json                  @default("[]") // field definitions for FORM type
  validationRules   Json                  @default("[]")
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  template          OnboardingTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  responses         ApplicationStepResponse[]

  @@unique([templateId, key])
  @@index([templateId])
  @@map("onboarding_template_steps")
}

model OnboardingApplication {
  id                      Int                        @id @default(autoincrement())
  uuid                    String                     @unique @db.VarChar(36)
  orgId                   Int?
  dropzoneId              Int?
  templateId              Int
  userId                  Int?
  externalContactEmail    String?                    @db.VarChar(255)
  externalContactPhone    String?                    @db.VarChar(30)
  externalContactName     String?                    @db.VarChar(200)
  sourceChannel           String                     @default("INTERNAL") @db.VarChar(30) // INTERNAL, EXTERNAL_LINK, INVITE, CAMPAIGN
  accessToken             String?                    @db.VarChar(255)
  tokenExpiresAt          DateTime?
  status                  OnboardingApplicationStatus @default(DRAFT)
  currentStepKey          String?                    @db.VarChar(100)
  completionPercent       Int                        @default(0)
  score                   Int?
  startedAt               DateTime                   @default(now())
  submittedAt             DateTime?
  approvedAt              DateTime?
  rejectedAt              DateTime?
  withdrawnAt             DateTime?
  assignedReviewerId      Int?
  rejectionReason         String?                    @db.Text
  reviewNotes             String?                    @db.Text
  metadataJson            Json                       @default("{}")
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt

  template                OnboardingTemplate         @relation(fields: [templateId], references: [id], onDelete: Restrict)
  user                    User?                      @relation("OnboardingApps", fields: [userId], references: [id], onDelete: SetNull)
  reviewer                User?                      @relation("OnboardingAppReviewer", fields: [assignedReviewerId], references: [id], onDelete: SetNull)
  organization            Organization?              @relation(fields: [orgId], references: [id], onDelete: SetNull)
  dropzone                Dropzone?                  @relation(fields: [dropzoneId], references: [id], onDelete: SetNull)
  stepResponses           ApplicationStepResponse[]
  applicationDocuments    ApplicationDocument[]
  waiverAcknowledgements  WaiverAcknowledgement[]
  notificationEvents      NotificationEvent[]

  @@index([templateId])
  @@index([userId])
  @@index([status])
  @@index([dropzoneId])
  @@index([accessToken])
  @@map("onboarding_applications")
}

model ApplicationStepResponse {
  id              Int                    @id @default(autoincrement())
  applicationId   Int
  stepId          Int
  valueJson       Json                   @default("{}")
  completed       Boolean                @default(false)
  completedAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  application     OnboardingApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  step            OnboardingTemplateStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([applicationId, stepId])
  @@index([applicationId])
  @@map("application_step_responses")
}

model ApplicationDocument {
  id                  Int                    @id @default(autoincrement())
  applicationId       Int
  userId              Int?
  documentType        String                 @db.VarChar(50)
  title               String                 @db.VarChar(255)
  fileUrl             String?                @db.VarChar(512)
  fileSize            Int?
  mimeType            String?                @db.VarChar(100)
  expiryDate          DateTime?
  verificationStatus  String                 @default("PENDING") @db.VarChar(20)
  reviewerNotes       String?                @db.Text
  reviewedBy          Int?
  reviewedAt          DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  application         OnboardingApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([verificationStatus])
  @@map("application_documents")
}

model WaiverAcknowledgement {
  id              Int                    @id @default(autoincrement())
  applicationId   Int?
  userId          Int?
  waiverId        Int
  signatureData   String?                @db.Text
  ipAddress       String?                @db.VarChar(50)
