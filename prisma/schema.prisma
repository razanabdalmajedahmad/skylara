  version         Int                    @default(1)
  createdAt       DateTime               @default(now())

  application     OnboardingApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  waiver          Waiver                 @relation(fields: [waiverId], references: [id], onDelete: Restrict)

  @@index([applicationId])
  @@index([userId])
  @@map("waiver_acknowledgements")
}

