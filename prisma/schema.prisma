  dropzoneId      Int
  activatedById   Int
  reason          String    @db.VarChar(255)
  windAtActivation Int?
  releasedById    Int?
  activatedAt     DateTime  @default(now())
  releasedAt      DateTime?

  dropzone        Dropzone  @relation("WeatherHoldDz", fields: [dropzoneId], references: [id], onDelete: Cascade)
  activatedBy     User      @relation("WeatherHoldActivator", fields: [activatedById], references: [id], onDelete: Restrict)

  @@index([dropzoneId])
  @@map("weather_holds")
}

// ============================================================================
