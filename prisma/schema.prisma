  currency        String    @default("USD") @db.VarChar(10)
  peakMultiplier  Decimal   @default(1.0) @db.Decimal(3, 2)
  groupDiscountPct Int      @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  dropzone        Dropzone  @relation("DzPricingDz", fields: [dropzoneId], references: [id], onDelete: Cascade)

  @@unique([dropzoneId, activityType])
  @@index([dropzoneId])
  @@map("dz_pricing")
}

// ============================================================================
// COACHING SESSIONS (P2 — structured coaching beyond AFF)
