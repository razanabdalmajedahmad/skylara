// ============================================================================
// LEARNING MODELS
// ============================================================================

model LearningCourse {
  id                      Int                    @id @default(autoincrement())
  uuid                    String                 @unique @db.VarChar(36)
  organizationId          Int?
  dropzoneId              Int?
  branchId                Int?
  title                   String                 @db.VarChar(255)
  slug                    String                 @unique @db.VarChar(300)
  description             String?                @db.Text
  shortDescription        String?                @db.VarChar(500)
  category                String?                @db.VarChar(100)
  level                   String?                @db.VarChar(50) // BEGINNER, INTERMEDIATE, ADVANCED, ALL_LEVELS
  accessType              LearningAccessType     @default(FREE)
  visibility              LearningVisibility     @default(PLATFORM_ONLY)
  status                  LearningCourseStatus   @default(DRAFT)
  coverImageUrl           String?                @db.VarChar(512)
  estimatedDurationMinutes Int?
  sortOrder               Int                    @default(0)
  isFeatured              Boolean                @default(false)
  prerequisiteCourseId    Int?
  createdById             Int
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  publishedAt             DateTime?
  archivedAt              DateTime?

  // Relations
  organization            Organization?          @relation("OrgLearningCourses", fields: [organizationId], references: [id])
  dropzone                Dropzone?              @relation("DzLearningCourses", fields: [dropzoneId], references: [id])
  createdBy               User                   @relation("LearningCourseCreator", fields: [createdById], references: [id])
  prerequisiteCourse      LearningCourse?        @relation("CoursePrerequisite", fields: [prerequisiteCourseId], references: [id])
  dependentCourses        LearningCourse[]       @relation("CoursePrerequisite")
  modules                 LearningCourseModule[]
  lessons                 LearningLesson[]
  enrollments             LearningEnrollment[]
  quizzes                 LearningQuiz[]
  certificates            LearningCertificate[]

  @@index([organizationId])
  @@index([dropzoneId])
  @@index([status])
  @@index([accessType])
  @@index([category])
  @@index([createdById])
  @@index([slug])
  @@map("learning_courses")
}

model LearningCourseModule {
  id          Int            @id @default(autoincrement())
  courseId     Int
  title       String         @db.VarChar(255)
  description String?        @db.Text
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  course      LearningCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     LearningLesson[]

  @@index([courseId])
  @@index([sortOrder])
  @@map("learning_course_modules")
}

model LearningLesson {
  id                Int                    @id @default(autoincrement())
  uuid              String                 @unique @db.VarChar(36)
  courseId           Int
  moduleId           Int?
  title             String                 @db.VarChar(255)
  description       String?                @db.Text
  contentType       LearningContentType    @default(VIDEO)
  videoProvider     LearningVideoProvider?
  videoAssetId      String?                @db.VarChar(255)  // Mux asset ID or Cloudflare video ID
  externalVideoUrl  String?                @db.VarChar(512)  // YouTube or external URL
  playbackId        String?                @db.VarChar(255)  // Mux signed playback ID
  transcriptUrl     String?                @db.VarChar(512)
  attachmentUrls    Json?                  // Array of { name, url, type }
  durationSeconds   Int?
  sortOrder         Int                    @default(0)
  isFree            Boolean                @default(false) // Override: free even in paid course
  isPublished       Boolean                @default(true)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  // Relations
  course            LearningCourse         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module            LearningCourseModule?  @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  progress          LearningLessonProgress[]

  @@index([courseId])
  @@index([moduleId])
  @@index([sortOrder])
  @@map("learning_lessons")
}

model LearningEnrollment {
  id                 Int                      @id @default(autoincrement())
  uuid               String                   @unique @db.VarChar(36)
  userId             Int
  courseId            Int
  sourceType         String?                  @db.VarChar(50)  // SELF, ADMIN_ASSIGNED, DZ_REQUIRED, BUNDLE
  enrollmentStatus   LearningEnrollmentStatus @default(ENROLLED)
  completionPercent  Float                    @default(0)
  startedAt          DateTime?
  completedAt        DateTime?
  lastAccessedAt     DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  // Relations
  user               User                     @relation("LearningEnrollmentUser", fields: [userId], references: [id])
  course             LearningCourse           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([enrollmentStatus])
  @@map("learning_enrollments")
}

model LearningLessonProgress {
  id               Int       @id @default(autoincrement())
  userId           Int
  lessonId         Int
  progressSeconds  Int       @default(0)
  completed        Boolean   @default(false)
  completedAt      DateTime?
  lastWatchedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  user             User               @relation("LearningProgressUser", fields: [userId], references: [id])
  lesson           LearningLesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("learning_lesson_progress")
}

model LearningQuiz {
  id          Int            @id @default(autoincrement())
  uuid        String         @unique @db.VarChar(36)
  courseId     Int
  title       String         @db.VarChar(255)
  description String?        @db.Text
  passScore   Int            @default(70) // percentage
  questions   Json           // Array of { question, options[], correctIndex, explanation? }
  timeLimit   Int?           // seconds
  maxAttempts Int?
  sortOrder   Int            @default(0)
  isPublished Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  course      LearningCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attempts    LearningQuizAttempt[]

  @@index([courseId])
  @@map("learning_quizzes")
}

model LearningQuizAttempt {
  id          Int           @id @default(autoincrement())
  userId      Int
  quizId      Int
  score       Int           // percentage
  passed      Boolean
  answers     Json?         // Array of { questionIndex, selectedIndex, correct }
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  createdAt   DateTime      @default(now())

  // Relations
  user        User          @relation("LearningQuizAttemptUser", fields: [userId], references: [id])
  quiz        LearningQuiz  @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@index([passed])
  @@map("learning_quiz_attempts")
}

model LearningCertificate {
  id                Int                      @id @default(autoincrement())
  uuid              String                   @unique @db.VarChar(36)
  userId            Int
  courseId           Int?
  eventId           Int?                     // boogie or camp id
  eventType         String?                  @db.VarChar(50) // CAMP, BOOGIE
  certificateType   LearningCertificateType
  title             String                   @db.VarChar(255)
  description       String?                  @db.Text
  issuedById        Int?
  issueDate         DateTime                 @default(now())
  expiresAt         DateTime?
  verificationCode  String                   @unique @db.VarChar(50)
  pdfUrl            String?                  @db.VarChar(512)
  visibility        LearningVisibility       @default(PLATFORM_ONLY)
  revokedAt         DateTime?
  revokeReason      String?                  @db.Text
  metadata          Json?                    // Additional data (score, hours, etc.)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  // Relations
  user              User                     @relation("LearningCertUser", fields: [userId], references: [id])
  issuedBy          User?                    @relation("LearningCertIssuer", fields: [issuedById], references: [id])
  course            LearningCourse?          @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@index([courseId])
  @@index([certificateType])
  @@index([verificationCode])
  @@index([visibility])
  @@map("learning_certificates")
}

model LearningAchievement {
  id              Int                      @id @default(autoincrement())
  uuid            String                   @unique @db.VarChar(36)
  userId          Int
  achievementType LearningAchievementType
  sourceType      String?                  @db.VarChar(50) // COURSE, QUIZ, CAMP, BOOGIE
  sourceId        Int?
  title           String                   @db.VarChar(255)
  description     String?                  @db.Text
  badgeIconUrl    String?                  @db.VarChar(512)
  metadata        Json?                    // Points, streaks, extras
  visibility      LearningVisibility       @default(PLATFORM_ONLY)
  createdAt       DateTime                 @default(now())

  // Relations
  user            User                     @relation("LearningAchievementUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([achievementType])
  @@index([sourceType, sourceId])
  @@map("learning_achievements")
}

model LearningSubscription {
  id               Int                        @id @default(autoincrement())
  uuid             String                     @unique @db.VarChar(36)
  userId           Int
  subscriptionTier LearningSubscriptionTier
  status           LearningSubscriptionStatus @default(ACTIVE)
  startsAt         DateTime                   @default(now())
  endsAt           DateTime?
  sourceType       String?                    @db.VarChar(50) // SELF, DZ_SPONSORED, GIFTED, BUNDLE
  sourceRef        String?                    @db.VarChar(255) // Stripe sub ID, etc.
  stripeSubId      String?                    @db.VarChar(255)
  cancelledAt      DateTime?
  cancelReason     String?                    @db.Text
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  // Relations
  user             User                       @relation("LearningSubUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([subscriptionTier])
  @@index([endsAt])
  @@map("learning_subscriptions")
}

model LearningEventAttendance {
  id               Int                        @id @default(autoincrement())
  uuid             String                     @unique @db.VarChar(36)
  userId           Int
  eventType        String                     @db.VarChar(50) // CAMP, BOOGIE, WORKSHOP, WEBINAR
  eventId          Int                        // references boogie.id or camp id
  attendanceStatus LearningAttendanceStatus   @default(REGISTERED)
  verifiedById     Int?
  verifiedAt       DateTime?
  notes            String?                    @db.Text
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  // Relations
  user             User                       @relation("LearningAttendanceUser", fields: [userId], references: [id])
  verifiedBy       User?                      @relation("LearningAttendanceVerifier", fields: [verifiedById], references: [id])

  @@unique([userId, eventType, eventId])
  @@index([userId])
  @@index([eventType, eventId])
  @@index([attendanceStatus])
  @@map("learning_event_attendance")
}

model LearningSavedContent {
  id          Int       @id @default(autoincrement())
  userId      Int
  contentType String    @db.VarChar(50) // COURSE, LESSON
  contentId   Int
  savedAt     DateTime  @default(now())

  // Relations
  user        User      @relation("LearningSavedUser", fields: [userId], references: [id])

  @@unique([userId, contentType, contentId])
  @@index([userId])
  @@map("learning_saved_content")
}

model LearningRecommendation {
  id          Int       @id @default(autoincrement())
  userId      Int
  contentType String    @db.VarChar(50) // COURSE, LESSON
  contentId   Int
  reason      String    @db.VarChar(255) // "Because you are an AFFI", "Based on camp history"
  score       Float     @default(0)
  dismissed   Boolean   @default(false)
  generatedAt DateTime  @default(now())

  // Relations
  user        User      @relation("LearningRecUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([score])
  @@index([dismissed])
  @@map("learning_recommendations")
}

// ============================================================================
// FEATURE FLAGS — DZ-scoped rollout control (Expert Feedback §10.3)
// ============================================================================

model FeatureFlag {
  id              Int       @id @default(autoincrement())
  key             String    @db.VarChar(100)
  label           String    @db.VarChar(255)
  description     String?   @db.Text
  dropzoneId      Int?
  branchId        Int?
  isEnabled       Boolean   @default(false)
  enabledById     Int?
  enabledAt       DateTime?
  rolloutPercent  Int       @default(100)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([key, dropzoneId, branchId])
  @@index([key])
  @@index([dropzoneId])
  @@map("feature_flags")
}

// ============================================================================
// MARKETING & ENGAGEMENT MODULE — Per Marketing_Engagement_Module_Master_Spec
