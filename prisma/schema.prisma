enum MarketingCampaignStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  PAUSED
  COMPLETED
  ARCHIVED
}

enum SurveyStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
}

enum ReferralStatus {
  ACTIVE
  EXPIRED
  CLAIMED
  CANCELLED
}

enum RewardClaimStatus {
  PENDING
  APPROVED
  FULFILLED
  REJECTED
  EXPIRED
}

enum LeaderboardWindow {
  ALL_TIME
  WEEKLY
  MONTHLY
  SEASONAL
}

enum SpinCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model MarketingCampaign {
  id           Int                     @id @default(autoincrement())
  dropzoneId   Int
  name         String                  @db.VarChar(255)
  description  String?                 @db.Text
  channel      String                  @db.VarChar(50) // IN_APP, PUSH, EMAIL, SMS, WHATSAPP
  status       MarketingCampaignStatus @default(DRAFT)
  audienceId   Int?
  templateId   Int?
  scheduledAt  DateTime?
  publishedAt  DateTime?
  pausedAt     DateTime?
  completedAt  DateTime?
  sendCount    Int                     @default(0)
  openCount    Int                     @default(0)
  clickCount   Int                     @default(0)
  createdById  Int
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  // Relations
  audience     MarketingAudience?      @relation(fields: [audienceId], references: [id])
  template     MarketingTemplate?      @relation(fields: [templateId], references: [id])
  sends        MarketingSend[]

  @@index([dropzoneId, status])
  @@index([scheduledAt])
  @@map("marketing_campaigns_v2")
}

model MarketingAudience {
  id           Int                     @id @default(autoincrement())
  dropzoneId   Int
  name         String                  @db.VarChar(255)
  description  String?                 @db.Text
  filters      Json                    // Segment criteria JSON
  estimatedSize Int                    @default(0)
  createdById  Int
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  // Relations
  campaigns    MarketingCampaign[]

  @@index([dropzoneId])
  @@map("marketing_audiences")
}

model MarketingTemplate {
  id           Int                     @id @default(autoincrement())
  dropzoneId   Int
  name         String                  @db.VarChar(255)
  channel      String                  @db.VarChar(50)
  subject      String?                 @db.VarChar(500)
  body         String                  @db.Text
  variables    Json?                   // Template variable definitions
  createdById  Int
  createdAt    DateTime                @default(now())
