  @@index([dropzoneId])
  @@map("booking_packages")
}

model Booking {
  id              Int           @id @default(autoincrement())
  uuid            String        @unique @db.VarChar(36)
  dropzoneId      Int
  userId          Int
  packageId       Int?
  bookingType     String        @db.VarChar(50) // TANDEM, AFF, COACHING, FUN_JUMP
  scheduledDate   DateTime      @db.Date
  scheduledTime   String?       @db.VarChar(5) // "10:00"
  status          BookingStatus @default(PENDING)
