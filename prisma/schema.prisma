model GuidedTourStep {
  id              String   @id @default(cuid())
  tourId          String   @map("tour_id")
  stepNumber      Int      @map("step_number")
  targetSelector  String   @map("target_selector")
  title           String
  description     String   @db.Text
  position        String   @default("bottom") // top | bottom | left | right
  route           String
  action          String?  // optional action label
  helpArticleSlug String?  @map("help_article_slug")
  createdAt       DateTime @default(now()) @map("created_at")

  tour            GuidedTour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, stepNumber])
  @@index([tourId])
  @@map("guided_tour_steps")
}

model UserTourProgress {
  id          String   @id @default(cuid())
  userId      Int      @map("user_id")
  tourId      String   @map("tour_id")
  completed   Boolean  @default(false)
  lastStepId  String?  @map("last_step_id")
  completedAt DateTime? @map("completed_at")
  dismissedAt DateTime? @map("dismissed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tourId])
  @@map("user_tour_progress")
}

model AssistantQuery {
  id               String   @id @default(cuid())
  query            String   @db.Text
  intent           String   @db.VarChar(50)
  role             String   @db.VarChar(50)
  currentRoute     String?  @db.VarChar(255)
  resultType       String   @db.VarChar(50)
  matchedFeatureId String?  @map("matched_feature_id")
  matchedArticleId String?  @map("matched_article_id")
  createdAt        DateTime @default(now()) @map("created_at")

  feedback         AssistantFeedback[]

  @@index([role])
  @@index([intent])
  @@map("assistant_queries")
}

model AssistantSuggestion {
  id              String   @id @default(cuid())
  prompt          String   @db.Text
  description     String   @db.Text
  category        String   @db.VarChar(100)
  applicableRoles Json     @default("[]")
  suggestedRoute  String?  @map("suggested_route") @db.VarChar(255)
  appliedRoute    String?  @map("applied_route") @db.VarChar(255)
  displayOrder    Int      @default(0) @map("display_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("assistant_suggestions")
}

model AssistantFeedback {
  id        String   @id @default(cuid())
  queryId   String   @map("query_id")
  helpful   Boolean
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  query     AssistantQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@index([queryId])
  @@map("assistant_feedback")
}

// ============================================================================
// AI — usage controls (Phase 11)
// ============================================================================

model AssistantUsageDaily {
  id        String   @id @default(cuid())
  dayKey    String   @db.VarChar(10) @map("day_key") // YYYY-MM-DD (UTC)
  orgId     Int?     @map("org_id")
  userId    Int      @map("user_id")
  usedCount Int      @default(0) @map("used_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dayKey, userId], name: "dayKey_userId")
  @@index([dayKey])
  @@index([orgId])
  @@index([userId])
  @@map("assistant_usage_daily")
}

// ============================================================================
// AI — observability (Phase 12)
// ============================================================================

model AssistantMetricEvent {
  id               String   @id @default(cuid())
  dayKey           String   @db.VarChar(10) @map("day_key") // YYYY-MM-DD (UTC)
  createdAt        DateTime @default(now()) @map("created_at")

  // Attribution (prompt-safe; no billing secrets)
  userId           Int?     @map("user_id")
  orgId            Int?     @map("org_id")
  subscriptionTier String?  @db.VarChar(50) @map("subscription_tier")

  // Metric identity
  metric           String   @db.VarChar(120)
  value            Int      @default(1)

  // Optional tags for alerting/reporting (prompt-safe)
  transport        String?  @db.VarChar(16) // json | sse
  outcome          String?  @db.VarChar(40)
  failureCategory  String?  @db.VarChar(40) @map("failure_category")
  tags             Json?    @map("tags")

  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([dayKey])
  @@index([metric, dayKey])
  @@index([orgId, dayKey])
  @@index([subscriptionTier, dayKey])
  @@map("assistant_metric_events")
}

// ============================================================================
// AUTHENTICATION & SECURITY — WebAuthn, OAuth, MFA
// ============================================================================

enum MfaDeviceType {
  TOTP
  WEBAUTHN
  SMS

  @@map("mfa_device_type")
}

enum OAuthProvider {
  GOOGLE
  APPLE
  GITHUB

  @@map("oauth_provider")
}

enum OnboardingRole {
  TANDEM_STUDENT
  FUN_JUMPER
  COACH
  DZ_MANAGER
  MANIFEST_STAFF
  PLATFORM_ADMIN

  @@map("onboarding_role")
}

enum PaymentIntentStatus {
  CREATED
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED

  @@map("payment_intent_status")
}

enum PayoutStatus {
  PENDING
  PROCESSING
  IN_TRANSIT
  PAID
  FAILED
  CANCELLED

  @@map("payout_status")
}

enum SplitRecipientType {
  DROPZONE
  COACH
  PLATFORM

  @@map("split_recipient_type")
}

enum LedgerEntryType {
  DEBIT
  CREDIT

  @@map("ledger_entry_type")
}

enum ReportBlockType {
  KPI_CARD
  LINE_CHART
  BAR_CHART
  PIE_CHART
  DATA_TABLE
  HEATMAP
  FUNNEL

  @@map("report_block_type")
}

model Passkey {
  id              Int       @id @default(autoincrement())
  userId          Int
  credentialId    String    @unique @db.VarChar(512)
  publicKey       Bytes
  counter         Int       @default(0)
  transports      Json      @default("[]")  // e.g. ["usb","ble","nfc","internal"]
  aaguid          String?   @db.VarChar(36)
  deviceName      String?   @db.VarChar(100)
  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkeys")
}

model OAuthAccount {
  id                  Int       @id @default(autoincrement())
  userId              Int
  provider            OAuthProvider
  providerAccountId   String    @db.VarChar(255)
  accessToken         String?   @db.Text
  refreshToken        String?   @db.Text
  tokenExpiresAt      DateTime?
  profileData         Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model MfaDevice {
  id              Int           @id @default(autoincrement())
  userId          Int
  type            MfaDeviceType
  secret          String?       @db.VarChar(255)   // encrypted TOTP secret
  verified        Boolean       @default(false)
  backupCodes     Json?                             // hashed backup codes
  phone           String?       @db.VarChar(20)    // for SMS MFA
  createdAt       DateTime      @default(now())
  lastUsedAt      DateTime?

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mfa_devices")
}

model LoginAttempt {
  id              Int       @id @default(autoincrement())
  email           String    @db.VarChar(255)
  ipAddress       String    @db.VarChar(45)
  userAgent       String?   @db.Text
  success         Boolean
  failureReason   String?   @db.VarChar(100)
  createdAt       DateTime  @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

// ============================================================================
// ONBOARDING
// ============================================================================

model OnboardingSession {
  id              Int             @id @default(autoincrement())
  userId          Int
  role            OnboardingRole
  currentStep     Int             @default(1)
  totalSteps      Int
  data            Json            @default("{}")    // accumulated form data
  completedAt     DateTime?
  abandonedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([role])
  @@map("onboarding_sessions")
}

// ============================================================================
// NOTIFICATIONS — Templates, Delivery Tracking, Webhooks
// ============================================================================

model NotificationTemplate {
  id              Int       @id @default(autoincrement())
  eventType       String    @db.VarChar(100)
  channel         NotificationChannel
  locale          String    @default("en") @db.VarChar(10)
  subject         String?   @db.VarChar(255)
  body            String    @db.Text
  variables       Json      @default("[]")   // available template variables
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([eventType, channel, locale])
  @@index([eventType])
  @@map("notification_templates")
}

model NotificationDelivery {
  id              Int       @id @default(autoincrement())
  notificationId  Int
  channel         NotificationChannel
  providerMessageId String? @db.VarChar(255)
  status          NotificationStatus @default(PENDING)
  attempts        Int       @default(0)
  lastAttemptAt   DateTime?
  deliveredAt     DateTime?
  failureReason   String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  notification    Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([status])
  @@map("notification_deliveries")
}

model Webhook {
  id              Int       @id @default(autoincrement())
  dropzoneId      Int
  url             String    @db.VarChar(512)
  events          Json      @default("[]")   // event types to subscribe
  secret          String    @db.VarChar(255) // HMAC signing secret
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  failCount       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  dropzone        Dropzone  @relation(fields: [dropzoneId], references: [id], onDelete: Cascade)

  @@index([dropzoneId])
  @@map("webhooks")
}

// ============================================================================
// PAYMENTS — Stripe Connect, Splits, Ledger
// ============================================================================

model StripeAccount {
  id                  Int       @id @default(autoincrement())
  userId              Int?
  dropzoneId          Int?
  stripeAccountId     String    @unique @db.VarChar(255)
  accountType         String    @db.VarChar(20)    // "express" | "standard"
  chargesEnabled      Boolean   @default(false)
  payoutsEnabled      Boolean   @default(false)
  onboardingComplete  Boolean   @default(false)
  detailsSubmitted    Boolean   @default(false)
  defaultCurrency     String    @default("usd") @db.VarChar(10)
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  dropzone            Dropzone? @relation(fields: [dropzoneId], references: [id], onDelete: SetNull)
  payouts             Payout[]

  @@index([userId])
  @@index([dropzoneId])
  @@map("stripe_accounts")
}

model PaymentIntent {
  id                      Int                 @id @default(autoincrement())
  uuid                    String              @unique @db.VarChar(36)
  userId                  Int
  dropzoneId              Int
  amount                  Int                           // total in cents
  currency                String              @default("usd") @db.VarChar(10)
  stripePaymentIntentId   String?             @unique @db.VarChar(255)
  status                  PaymentIntentStatus @default(CREATED)
  description             String?             @db.VarChar(255)
  referenceType           String?             @db.VarChar(50)  // "booking", "wallet_topup", "coaching", "shop"
  referenceId             Int?
  metadata                Json?
  refundedAmount          Int                 @default(0)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  user                    User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  dropzone                Dropzone            @relation(fields: [dropzoneId], references: [id], onDelete: Restrict)
  splits                  PaymentSplit[]
  ledgerEntries           LedgerEntry[]

  @@index([userId])
  @@index([dropzoneId])
  @@index([status])
  @@index([createdAt])
  @@map("payment_intents")
}

model PaymentSplit {
  id                  Int                @id @default(autoincrement())
  paymentIntentId     Int
  recipientType       SplitRecipientType
  recipientId         Int                           // userId or dropzoneId depending on type
  amount              Int                           // in cents
  platformFee         Int                @default(0)
  stripeTransferId    String?            @db.VarChar(255)
  status              String             @default("pending") @db.VarChar(50)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  paymentIntent       PaymentIntent      @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)

  @@index([paymentIntentId])
  @@index([recipientType, recipientId])
  @@map("payment_splits")
}

model Payout {
  id                  Int           @id @default(autoincrement())
  stripeAccountId     Int
  amount              Int
  currency            String        @default("usd") @db.VarChar(10)
  stripePayoutId      String?       @unique @db.VarChar(255)
  status              PayoutStatus  @default(PENDING)
  scheduledAt         DateTime?
  initiatedAt         DateTime?
  paidAt              DateTime?
  failureReason       String?       @db.Text
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  stripeAccount       StripeAccount @relation(fields: [stripeAccountId], references: [id], onDelete: Cascade)

  @@index([stripeAccountId])
  @@index([status])
  @@index([scheduledAt])
  @@map("payouts")
}

model LedgerEntry {
  id                  Int             @id @default(autoincrement())
  paymentIntentId     Int?
  transactionId       Int?
  accountType         String          @db.VarChar(50)  // "revenue", "payout", "fee", "refund"
  accountId           Int                              // entity id
  entryType           LedgerEntryType
  amount              Int                              // always positive, direction from entryType
  currency            String          @default("usd") @db.VarChar(10)
  balanceAfter        Int
  description         String          @db.VarChar(255)
  createdAt           DateTime        @default(now())

  paymentIntent       PaymentIntent?  @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)

  @@index([accountType, accountId])
  @@index([paymentIntentId])
  @@index([createdAt])
  @@map("ledger_entries")
}

// ============================================================================
// ASSISTANT — Conversations
// ============================================================================

model AssistantConversation {
  id              String    @id @default(cuid())
  userId          Int
  title           String?   @db.VarChar(255)
  messages        Json      @default("[]")    // array of {role, content, timestamp}
  context         Json?                       // page context, user role, DZ info
  messageCount    Int       @default(0)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("assistant_conversations")
}

// ============================================================================
// REPORT BUILDER — Dashboards & Blocks
// ============================================================================

model ReportDashboard {
  id              Int       @id @default(autoincrement())
  userId          Int
  dropzoneId      Int?
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  layout          Json      @default("[]")    // grid layout config
  isDefault       Boolean   @default(false)
  isShared        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dropzone        Dropzone? @relation(fields: [dropzoneId], references: [id], onDelete: SetNull)
  blocks          ReportBlock[]

  @@index([userId])
  @@index([dropzoneId])
  @@map("report_dashboards")
}

model ReportBlock {
  id              Int             @id @default(autoincrement())
  dashboardId     Int
  blockType       ReportBlockType
  title           String          @db.VarChar(255)
  dataSource      String          @db.VarChar(100) // "revenue", "bookings", "payouts", etc.
  query           Json            @default("{}")   // filters, groupBy, aggregation
  position        Json            @default("{}")   // {x, y, w, h} grid position
  size            Json            @default("{}")   // {minW, minH, maxW, maxH}
  config          Json            @default("{}")   // visualization config (colors, labels, etc.)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  dashboard       ReportDashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@map("report_blocks")
}

// ============================================================================
// BOOGIES MODULE — Events, camps, competitions, expeditions
// ============================================================================

model Boogie {
  id                    Int       @id @default(autoincrement())
  uuid                  String    @unique @db.VarChar(36)
  dropzoneId            Int
  title                 String    @db.VarChar(200)
  slug                  String    @db.VarChar(200)
  subtitle              String?   @db.VarChar(300)
  shortDescription      String?   @db.Text
  fullDescription       String?   @db.LongText
  eventType             String    @db.VarChar(50) // BOOGIE, SKILLS_CAMP, COACH_CAMP, etc.
  discipline            String?   @db.VarChar(50) // BELLY, FREEFLY, ANGLE, etc.
  organizerName         String?   @db.VarChar(200)
  country               String?   @db.VarChar(100)
  city                  String?   @db.VarChar(100)
  timezone              String    @default("UTC") @db.VarChar(50)
  startDate             DateTime
  endDate               DateTime
  registrationOpenAt    DateTime?
  registrationCloseAt   DateTime?
  status                String    @default("DRAFT") @db.VarChar(30) // DRAFT, PUBLISHED, REGISTRATION_OPEN, FULL, IN_PROGRESS, COMPLETED, CANCELLED, ARCHIVED
  visibility            String    @default("PUBLIC") @db.VarChar(20) // PUBLIC, UNLISTED, PRIVATE, INVITE_ONLY
  maxParticipants       Int       @default(100)
  currentParticipants   Int       @default(0)
  waitlistEnabled       Boolean   @default(true)
  approvalMode          String    @default("AUTO_APPROVE") @db.VarChar(30) // AUTO_APPROVE, MANUAL_REVIEW, WAITLIST_FIRST, INVITE_ONLY
  depositRequired       Boolean   @default(false)
  depositAmountCents    Int?
  currency              String    @default("AED") @db.VarChar(10)
  heroImageUrl          String?   @db.VarChar(500)
  promoVideoUrl         String?   @db.VarChar(500)
  termsText             String?   @db.LongText
  cancellationPolicy    String?   @db.Text
  liabilityText         String?   @db.Text
  insuranceRequirement  String?   @db.Text
  minLicense            String?   @db.VarChar(20) // A, B, C, D, STUDENT, NONE
  minJumps              Int?
  minTunnelHours        Int?
  aadRequired           Boolean   @default(true)
  gearApprovalRequired  Boolean   @default(false)
  ownRigRequired        Boolean   @default(false)
  rentalAvailable       Boolean   @default(true)
  formSchema            Json      @default("[]") // Dynamic registration form fields
  templateId            Int?
  createdBy             Int
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  dropzone              Dropzone  @relation("BoogieDropzone", fields: [dropzoneId], references: [id], onDelete: Cascade)
  creator               User      @relation("BoogieCreator", fields: [createdBy], references: [id])
  registrations         BoogieRegistration[]
  packages              BoogiePackage[]
  calendarBlocks        BoogieCalendarBlock[]
  groups                BoogieGroup[]
  staffAssignments      BoogieStaffAssignment[] @relation("BoogieStaffAssignments")
  announcements         BoogieAnnouncement[]

  @@unique([dropzoneId, slug])
  @@index([dropzoneId])
  @@index([status])
  @@index([startDate])
  @@map("boogies")
}

model BoogiePackage {
  id                Int       @id @default(autoincrement())
  boogieId          Int
  name              String    @db.VarChar(200)
  description       String?   @db.Text
  priceCents        Int
  currency          String    @default("AED") @db.VarChar(10)
  packageType       String    @db.VarChar(50) // TICKET_ONLY, TICKET_GEAR, COACH, CAMP, ACCOMMODATION, PREMIUM
  maxSlots          Int?
  soldCount         Int       @default(0)
  includes          Json      @default("[]")
  isActive          Boolean   @default(true)
  sortOrder         Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  boogie            Boogie    @relation(fields: [boogieId], references: [id], onDelete: Cascade)

  @@index([boogieId])
  @@map("boogie_packages")
}

model BoogieRegistration {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique @db.VarChar(36)
  boogieId          Int
  userId            Int?
  email             String    @db.VarChar(255)
  firstName         String    @db.VarChar(100)
  lastName          String    @db.VarChar(100)
  phone             String?   @db.VarChar(30)
  nationality       String?   @db.VarChar(100)
  dateOfBirth       DateTime?
  homeDropzone      String?   @db.VarChar(200)
  numberOfJumps     Int?
  tunnelTime        Int?
  licenseType       String?   @db.VarChar(20)
  licenseNumber     String?   @db.VarChar(50)
  aadConfirmed      Boolean   @default(false)
  gearOwnership     String?   @db.VarChar(50) // OWN_RIG, RENTAL_NEEDED, PARTIAL
  canopySize        Int?      // sq ft
  wingLoading       Decimal?  @db.Decimal(4,2)
  jumpsLast90Days   Int?
  preferredDiscipline String? @db.VarChar(50)
  accommodationChoice String? @db.VarChar(50)
  jerseySize        String?   @db.VarChar(10)
  foodRestrictions  String?   @db.Text
  emergencyContact  String?   @db.VarChar(200)
  notes             String?   @db.Text
  waiverAccepted    Boolean   @default(false)
  termsAccepted     Boolean   @default(false)
  formData          Json      @default("{}") // Dynamic form field responses
  packageId         Int?
  status            String    @default("PENDING") @db.VarChar(30) // PENDING, APPROVED, REJECTED, WAITLISTED, CANCELLED, CHECKED_IN
  paymentStatus     String    @default("UNPAID") @db.VarChar(20) // UNPAID, DEPOSIT_PAID, FULLY_PAID, REFUNDED
  amountPaidCents   Int       @default(0)
  registeredAt      DateTime  @default(now())
  approvedAt        DateTime?
  approvedBy        Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  boogie            Boogie    @relation(fields: [boogieId], references: [id], onDelete: Cascade)
  user              User?     @relation("BoogieRegUser", fields: [userId], references: [id])

  @@index([boogieId])
  @@index([userId])
  @@index([status])
  @@map("boogie_registrations")
}

// ============================================================================
// BOOGIES PHASE 1 — Calendar, Groups, Announcements, Templates
// ============================================================================

model BoogieCalendarBlock {
  id              Int       @id @default(autoincrement())
  boogieId        Int
  title           String    @db.VarChar(200)
  blockType       String    @db.VarChar(50) // JUMP_ROTATION, TUNNEL_ROTATION, CANOPY_BLOCK, BRIEFING, ARRIVAL, REGISTRATION, WEATHER_HOLD, SOCIAL, CONTINGENCY, DEPARTURE
  dayIndex        Int       // 0-based day of event
  startTime       String    @db.VarChar(5) // HH:MM
  endTime         String    @db.VarChar(5)
  groupIds        Json      @default("[]") // IDs of assigned groups
  instructorIds   Json      @default("[]")
  notes           String?   @db.Text
  color           String?   @db.VarChar(9)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  boogie          Boogie    @relation(fields: [boogieId], references: [id], onDelete: Cascade)

  @@index([boogieId, dayIndex])
  @@map("boogie_calendar_blocks")
}

model BoogieGroup {
  id              Int       @id @default(autoincrement())
  boogieId        Int
  name            String    @db.VarChar(100)
  groupType       String    @db.VarChar(30) // JUMP, TUNNEL, CANOPY
  discipline      String?   @db.VarChar(50)
  instructorId    Int?
  maxSize         Int       @default(8)
  targetSkillBand String?   @db.VarChar(30) // BEGINNER, INTERMEDIATE, ADVANCED, MIXED
  isLocked        Boolean   @default(false)
  safetyFlags     Json      @default("[]")
  manualOverride  Boolean   @default(false)
  overrideReason  String?   @db.Text
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

