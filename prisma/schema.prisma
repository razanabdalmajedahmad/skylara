// DATA MANAGEMENT — Demo Environment, Import/Export, Reset
// ============================================================================

model DataOperation {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique @default(uuid()) @db.VarChar(36)
  operationType     String    @db.VarChar(30) // IMPORT, EXPORT, DEMO_LOAD, DEMO_CLEAR, TENANT_RESET
  status            String    @db.VarChar(20) @default("PENDING") // PENDING, PREVIEW, RUNNING, COMPLETED, FAILED, ROLLED_BACK
  userId            Int
  dropzoneId        Int?
  organizationId    Int?
  scenarioKey       String?   @db.VarChar(50) // e.g. "turbine-dz", "tandem-focused"
  batchId           String?   @db.VarChar(36) // UUID for rollback grouping
  recordsAffected   Int       @default(0)
  modulesAffected   Json?     // ["users","aircraft","loads",...]
  previewData       Json?     // dry-run summary: { users: 80, loads: 20, ... }
  errorLog          Json?     // [{table:"loads", row:5, error:"..."}]
  conflictStrategy  String?   @db.VarChar(20) // SKIP, REPLACE, MERGE
  exportFormat      String?   @db.VarChar(10) // JSON, CSV
  exportUrl         String?   @db.Text // S3 or local path for export downloads
  startedAt         DateTime?
  completedAt       DateTime?
  rolledBackAt      DateTime?
  createdAt         DateTime  @default(now())

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dropzone          Dropzone? @relation(fields: [dropzoneId], references: [id], onDelete: SetNull)
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([dropzoneId])
  @@index([operationType])
  @@index([status])
  @@index([batchId])
  @@index([createdAt])
  @@map("data_operations")
}

model SyncOutbox {
  id              Int       @id @default(autoincrement())
  deviceId        String    @db.VarChar(100)
  userId          Int
  dropzoneId      Int
  action          String    @db.VarChar(50)
  entityType      String    @db.VarChar(50)
  entityId        Int
  payload         Json
  status          SyncStatus @default(PENDING)
  idempotencyKey  String    @unique @db.VarChar(255)
  conflictData    Json?
  createdAt       DateTime  @default(now())
  syncedAt        DateTime?

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dropzone        Dropzone  @relation(fields: [dropzoneId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dropzoneId])
  @@index([status])
  @@index([createdAt])
  @@map("sync_outbox")
}

// ============================================================================
// ATHLETES, LICENSES & COMPLIANCE
// ============================================================================

model Athlete {
  id              Int           @id @default(autoincrement())
  userId          Int           @unique
  homeDropzoneId  Int?
  uspaMemberId    String?       @db.VarChar(50)
  licenseLevel    LicenseLevel  @default(NONE)
  totalJumps      Int           @default(0)
  lastJumpDate    DateTime?
  disciplines     Json          @default("[]")  // string array: ["RW","Freefly","Wingsuit"]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeDropzone    Dropzone?     @relation("HomeDropzone", fields: [homeDropzoneId], references: [id], onDelete: SetNull)
  licenses        License[]
  currencyChecks  CurrencyCheck[]
  logbookEntries  LogbookEntry[]
  affRecords      AffRecord[]   @relation("AffStudent")
  skills          AthleteSkill[]
  interests       AthleteInterest?

  @@index([homeDropzoneId])
  @@map("athletes")
}

model License {
  id                  Int                 @id @default(autoincrement())
  userId              Int
  type                String              @db.VarChar(20) // USPA, BPA, APF, FFP, DFV
  number              String?             @db.VarChar(50)
  level               LicenseLevel
  issuedAt            DateTime?
  expiresAt           DateTime?
  verifiedBy          Int?
  verifiedAt          DateTime?
  verificationMethod  VerificationMethod?
  evidenceUrl         String?             @db.VarChar(512)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  athlete             Athlete?            @relation(fields: [userId], references: [userId], map: "licenses_athleteId_fkey")

  @@index([userId])
  @@index([expiresAt])
  @@map("licenses")
}

model CurrencyCheck {
  id              Int       @id @default(autoincrement())
  userId          Int
  lastJumpDate    DateTime?
  isCurrent       Boolean
  ruleApplied     String    @db.VarChar(100) // e.g. "A/B: 60 days", "Student: 30 days"
  checkedAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  athlete         Athlete?  @relation(fields: [userId], references: [userId], map: "currency_checks_athleteId_fkey")

  @@index([userId])
  @@index([checkedAt])
  @@map("currency_checks")
}

model LogbookEntry {
  id                  Int       @id @default(autoincrement())
  userId              Int
  loadId              Int?
  dropzoneId          Int
  jumpNumber          Int
  altitude            Int?      // feet
  freefallTime        Int?      // seconds
  deploymentAltitude  Int?      // feet
  canopySize          Int?      // sq ft
  jumpType            JumpType?
  disciplines         Json      @default("[]")
  notes               String?   @db.Text
  coachSignOffId      Int?
  instructorSignOffId Int?
  gpsData             Json?
  createdAt           DateTime  @default(now())

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  athlete             Athlete?  @relation(fields: [userId], references: [userId], map: "logbook_entries_athleteId_fkey")
  load                Load?     @relation(fields: [loadId], references: [id], onDelete: SetNull)
  dropzone            Dropzone  @relation("LogbookDropzone", fields: [dropzoneId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([loadId])
  @@index([dropzoneId])
  @@map("logbook_entries")
}

// ============================================================================
// CG CHECKS — Append-only safety audit trail
// ============================================================================

model CgCheck {
  id              Int       @id @default(autoincrement())
  loadId          Int
  aircraftId      Int
  performedById   Int
  totalWeight     Int       // lbs
  fuelWeight      Int       // lbs
  pilotWeight     Int       // lbs
  passengerWeight Int       // lbs
  calculatedCg    Decimal   @db.Decimal(6, 2) // inches from datum
  forwardLimit    Decimal   @db.Decimal(6, 2)
  aftLimit        Decimal   @db.Decimal(6, 2)
  result          CgResult
  overrideReason  String?   @db.Text
  overrideById    Int?
  createdAt       DateTime  @default(now())

  // APPEND-ONLY: never update cg_checks rows
  load            Load      @relation(fields: [loadId], references: [id], onDelete: Cascade)
  aircraft        Aircraft  @relation(fields: [aircraftId], references: [id], onDelete: Restrict)
  performedBy     User      @relation("CgPerformedBy", fields: [performedById], references: [id], onDelete: Restrict)

  @@index([loadId])
  @@index([aircraftId])
  @@index([createdAt])
  @@map("cg_checks")
}

// ============================================================================
// WAITLIST & LOAD NOTES
// ============================================================================

model WaitlistEntry {
  id              Int       @id @default(autoincrement())
  dropzoneId      Int
  userId          Int
  loadId          Int?
  slotType        SlotType?
  priority        Int       @default(0)
