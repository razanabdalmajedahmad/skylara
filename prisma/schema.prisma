  uuid                  String             @unique @db.VarChar(36)
  orgId                 Int?
  dropzoneId            Int?
  name                  String             @db.VarChar(255)
  description           String?            @db.Text
  segmentId             Int?
  channelsJson          Json               @default("[]") // ["EMAIL", "PUSH", "WHATSAPP"]
  triggerType           CampaignTriggerType @default(MANUAL)
  status                CampaignStatus     @default(DRAFT)
  scheduleJson          Json?              // cron or datetime schedule
  templateMappingJson   Json               @default("{}") // channel -> template_id mapping
  sentCount             Int                @default(0)
  openCount             Int                @default(0)
  clickCount            Int                @default(0)
  failCount             Int                @default(0)
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  segment               Segment?           @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  organization          Organization?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  dropzone              Dropzone?          @relation(fields: [dropzoneId], references: [id], onDelete: SetNull)
  events                NotificationEvent[]

  @@index([status])
  @@index([segmentId])
  @@index([dropzoneId])
  @@map("notification_campaigns")
}

model NotificationEvent {
  id                  Int                    @id @default(autoincrement())
  orgId               Int?
  userId              Int?
  applicationId       Int?
  campaignId          Int?
  eventType           String                 @db.VarChar(100)
  channel             NotificationChannel
  subject             String?                @db.VarChar(255)
  body                String?                @db.Text
  payloadJson         Json                   @default("{}")
  status              NotificationStatus     @default(PENDING)
  providerMessageId   String?                @db.VarChar(255)
  providerResponseJson Json?
  attempts            Int                    @default(0)
  sentAt              DateTime?
  deliveredAt         DateTime?
  openedAt            DateTime?
  clickedAt           DateTime?
  failedAt            DateTime?
  failureReason       String?                @db.Text
  createdAt           DateTime               @default(now())

  user                User?                  @relation("NotificationEvents", fields: [userId], references: [id], onDelete: SetNull)
  application         OnboardingApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  campaign            NotificationCampaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([applicationId])
  @@index([campaignId])
  @@index([status])
  @@index([eventType])
  @@index([sentAt])
  @@map("notification_events")
}

model PushDevice {
  id              Int       @id @default(autoincrement())
  userId          Int
  platform        String    @db.VarChar(20) // IOS, ANDROID, WEB
  pushToken       String    @db.VarChar(500)
  appVersion      String?   @db.VarChar(20)
  deviceName      String?   @db.VarChar(100)
  lastSeenAt      DateTime  @default(now())
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pushToken])
  @@index([userId])
  @@index([active])
  @@map("push_devices")
}

model WhatsAppConsent {
  id              Int            @id @default(autoincrement())
  userId          Int?
  phone           String         @db.VarChar(30)
  status          ConsentStatus  @default(PENDING)
  optedInAt       DateTime?
  optedOutAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([phone])
  @@index([userId])
  @@map("whatsapp_consents")
}

model CommunicationPreference {
  id                  Int       @id @default(autoincrement())
  userId              Int       @unique
  emailEnabled        Boolean   @default(true)
  whatsappEnabled     Boolean   @default(false)
  pushEnabled         Boolean   @default(true)
  inAppEnabled        Boolean   @default(true)
  smsEnabled          Boolean   @default(false)
  preferredLanguage   String    @default("en") @db.VarChar(10)
  quietHoursStart     String?   @db.VarChar(5) // "22:00"
  quietHoursEnd       String?   @db.VarChar(5) // "08:00"
  digestFrequency     String    @default("REALTIME") @db.VarChar(20) // REALTIME, DAILY, WEEKLY
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("communication_preferences")
}

// ============================================================================
// SEGMENTS & AUTOMATIONS
// ============================================================================

model Segment {
  id              Int                    @id @default(autoincrement())
  uuid            String                 @unique @db.VarChar(36)
  orgId           Int?
  dropzoneId      Int?
  name            String                 @db.VarChar(255)
  description     String?                @db.Text
  rulesJson       Json                   @default("[]") // array of rule objects
  active          Boolean                @default(true)
  cachedCount     Int?
  lastComputedAt  DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  campaigns       NotificationCampaign[]
  automations     AutomationRule[]
  organization    Organization?          @relation(fields: [orgId], references: [id], onDelete: SetNull)
  dropzone        Dropzone?              @relation(fields: [dropzoneId], references: [id], onDelete: SetNull)

  @@index([dropzoneId])
  @@index([active])
  @@map("segments")
}

model AutomationRule {
  id                Int                 @id @default(autoincrement())
  uuid              String              @unique @db.VarChar(36)
  orgId             Int?
  dropzoneId        Int?
  name              String              @db.VarChar(255)
  description       String?             @db.Text
  category          String?             @db.VarChar(50) // ONBOARDING, NOTIFICATION, APPROVAL, FOLLOWUP
  triggerEvent      AutomationTriggerEvent
  conditionsJson    Json                @default("[]")
  actionsJson       Json                @default("[]") // what to do: send_notification, change_status, assign_reviewer
  segmentId         Int?
  active            Boolean             @default(true)
  lastRunAt         DateTime?
  runCount          Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  segment           Segment?            @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  organization      Organization?       @relation(fields: [orgId], references: [id], onDelete: SetNull)
  dropzone          Dropzone?           @relation(fields: [dropzoneId], references: [id], onDelete: SetNull)

  @@index([triggerEvent])
  @@index([active])
  @@index([dropzoneId])
  @@map("automation_rules")
}

// ============================================================================
// AI ASSISTANT — Recommendations for Onboarding & Notifications
// ============================================================================

model AssistantRecommendation {
  id                      Int                   @id @default(autoincrement())
  orgId                   Int?
  dropzoneId              Int?
  userId                  Int?
  type                    RecommendationType
  title                   String                @db.VarChar(255)
  description             String                @db.Text
  recommendationPayload   Json                  @default("{}")
  status                  RecommendationStatus  @default(PENDING)
  priority                String                @default("MEDIUM") @db.VarChar(20)
  actionTakenAt           DateTime?
  actionByUserId          Int?                  // Who accepted/rejected/edited
  actionReason            String?               @db.Text   // Why (required for reject)
  editedPayload           Json?                 // Modified payload if status=EDITED
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  organization            Organization?         @relation(fields: [orgId], references: [id], onDelete: SetNull)
  dropzone                Dropzone?             @relation(fields: [dropzoneId], references: [id], onDelete: SetNull)
  user                    User?                 @relation("AssistantRecs", fields: [userId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@index([dropzoneId])
  @@map("assistant_recommendations")
}

// ============================================================================
// WAIVER CENTER — Templates, Versions, Sections, Fields, Submissions
// ============================================================================

enum WaiverFieldType {
  TEXT
  EMAIL
  PHONE
  NUMBER
  DATE
  SELECT
  CHECKBOX
  TEXTAREA
  FILE_UPLOAD
  SIGNATURE
  INITIALS
  PHOTO_CONSENT
  POLICY_CONSENT

  @@map("waiver_field_type")
}

enum WaiverSubmissionStatus {
  PENDING_SIGNATURE
  SIGNED
  VERIFIED
  EXPIRED
  REVOKED

  @@map("waiver_submission_status")
}

model WaiverTemplate {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique @db.VarChar(36)
  orgId             Int?
  dropzoneId        Int
  eventId           Int?
  category          String    @default("general") @db.VarChar(50) // general, tandem, student, visiting_jumper, coach, staff, event, camp
  title             String    @db.VarChar(255)
  description       String?   @db.Text
  waiverType        WaiverType
  slug              String    @db.VarChar(100)
  audienceType      String    @default("both") @db.VarChar(20) // internal_user, external_guest, both
  requireMinor      Boolean   @default(false)
  requireMedical    Boolean   @default(false)
  status            String    @default("DRAFT") @db.VarChar(20) // DRAFT, PUBLISHED, ARCHIVED
  currentVersionId  Int?
  configJson        Json      @default("{}")
  createdByUserId   Int?
  updatedByUserId   Int?
  archivedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  dropzone          Dropzone  @relation("WaiverTemplates", fields: [dropzoneId], references: [id], onDelete: Cascade)
  createdBy         User?     @relation("WaiverTemplateCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  versions          WaiverTemplateVersion[]
  publishLinks      WaiverPublishLink[]
  signRequests      WaiverSignRequest[]
  tags              WaiverTemplateTag[]

  @@unique([dropzoneId, slug])
  @@index([dropzoneId])
  @@index([status])
  @@index([category])
  @@map("waiver_templates_v2")
}

model WaiverTemplateVersion {
  id                    Int       @id @default(autoincrement())
  templateId            Int
  version               Int
  status                String    @default("DRAFT") @db.VarChar(20) // DRAFT, PUBLISHED, ARCHIVED
  titleSnapshot         String    @db.VarChar(255)
  descriptionSnapshot   String?   @db.Text
  content               Json      @default("{}") // full version snapshot: sections + fields
  checksum              String?   @db.VarChar(64) // integrity verification
  publishedAt           DateTime?
  publishedByUserId     Int?
  effectiveFrom         DateTime?
  effectiveUntil        DateTime?
  rollbackOfVersionId   Int?
  archivedAt            DateTime?
  createdAt             DateTime  @default(now())

  template              WaiverTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sections              WaiverSection[]
  submissions           WaiverSubmission[]
  signRequests          WaiverSignRequest[]

  @@unique([templateId, version])
  @@index([templateId])
  @@index([status])
  @@map("waiver_template_versions")
}

model WaiverSection {
  id              Int       @id @default(autoincrement())
  versionId       Int
  key             String    @db.VarChar(100)
  title           String    @db.VarChar(255)
  content         String?   @db.LongText // rich text content
  sectionType     String    @db.VarChar(50) // HEADING, PARAGRAPH, CLAUSE, CHECKBOX_GROUP, INITIALS, SIGNATURE_BLOCK, CUSTOM_FIELDS, GUARDIAN_SECTION
  orderIndex      Int
  required        Boolean   @default(true)
  conditionJson   Json      @default("{}")
  createdAt       DateTime  @default(now())

  version         WaiverTemplateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  fields          WaiverField[]

  @@index([versionId])
  @@map("waiver_sections")
}

model WaiverField {
  id              Int              @id @default(autoincrement())
  sectionId       Int
  key             String           @db.VarChar(100)
  label           String           @db.VarChar(255)
  fieldType       WaiverFieldType
  required        Boolean          @default(false)
  placeholder     String?          @db.VarChar(255)
  optionsJson     Json             @default("[]")
  orderIndex      Int
  createdAt       DateTime         @default(now())

  section         WaiverSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
  @@map("waiver_fields")
}

model WaiverPublishLink {
  id                        Int       @id @default(autoincrement())
  templateId                Int
  versionId                 Int?
  orgId                     Int?
  slug                      String    @db.VarChar(100)
  linkType                  String    @db.VarChar(30) // PUBLIC, TOKEN, INVITE, EVENT, BOOKING
  token                     String?   @unique @db.VarChar(255)
  allowGuest                Boolean   @default(true)
  requireLogin              Boolean   @default(false)
  requireEmailVerification  Boolean   @default(false)
  requirePhoneVerification  Boolean   @default(false)
  expiresAt                 DateTime?
  eventId                   Int?
  dropzoneId                Int?
  bookingId                 Int?
  maxUses                   Int?
  useCount                  Int       @default(0)
  active                    Boolean   @default(true)
  metadataJson              Json?
  createdByUserId           Int?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  template                  WaiverTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  signRequests              WaiverSignRequest[]

  @@index([templateId])
  @@index([token])
  @@index([slug])
  @@map("waiver_publish_links")
}

model WaiverSubmission {
  id                      Int                       @id @default(autoincrement())
  uuid                    String                    @unique @db.VarChar(36)
  orgId                   Int?
  templateId              Int
  versionId               Int
  publishLinkId           Int?
  signRequestId           Int?
  userId                  Int?
  athleteProfileId        Int?
  bookingId               Int?
  eventRegistrationId     Int?
  submissionStatus        String                    @default("draft") @db.VarChar(20) // draft, in_progress, submitted, signed, reviewed, invalidated
  startedAt               DateTime                  @default(now())
  submittedAt             DateTime?
  reviewedAt              DateTime?
  invalidatedAt           DateTime?
  invalidationReason      String?                   @db.Text
  signerType              String                    @default("self") @db.VarChar(20) // self, guardian, admin_kiosk, staff_assisted
  signerName              String                    @db.VarChar(200)
  signerEmail             String?                   @db.VarChar(255)
  signerPhone             String?                   @db.VarChar(30)
  signerIp                String?                   @db.VarChar(50)
  signerUserAgent         String?                   @db.VarChar(500)
  signerCountry           String?                   @db.VarChar(50)
  signerTimezone          String?                   @db.VarChar(50)
  locale                  String                    @default("en") @db.VarChar(10)
  isMinor                 Boolean                   @default(false)
  guardianRequired        Boolean                   @default(false)
  guardianName            String?                   @db.VarChar(200)
  guardianRelation        String?                   @db.VarChar(100)
  answersJson             Json                      @default("{}")
  renderedHtmlSnapshot    String?                   @db.LongText
  generatedPdfUrl         String?                   @db.VarChar(512)
  metadataJson            Json?
  sourceChannel           String                    @default("WEB") @db.VarChar(30) // WEB, KIOSK, APP, EMAIL, WHATSAPP
  eventId                 Int?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  version                 WaiverTemplateVersion     @relation(fields: [versionId], references: [id], onDelete: Restrict)
  user                    User?                     @relation("WaiverSubmissions", fields: [userId], references: [id], onDelete: SetNull)
  signRequest             WaiverSignRequest?        @relation(fields: [signRequestId], references: [id], onDelete: SetNull)
  signatures              WaiverSubmissionSignature[]
  reviews                 WaiverSubmissionReview[]

  @@index([versionId])
  @@index([templateId])
  @@index([userId])
  @@index([signerEmail])
  @@index([submissionStatus])
  @@index([submittedAt])
  @@index([signRequestId])
  @@map("waiver_submissions")
}

model WaiverSubmissionSignature {
  id              Int       @id @default(autoincrement())
  submissionId    Int
  signerType      String    @db.VarChar(30) // PARTICIPANT, GUARDIAN, WITNESS
  signatureData   String    @db.LongText // base64 image or typed name
  signatureMethod String    @db.VarChar(30) // TYPED, DRAWN, BIOMETRIC
  ipAddress       String?   @db.VarChar(50)
  signedAt        DateTime  @default(now())

  submission      WaiverSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("waiver_submission_signatures")
}

model WaiverDeliveryLog {
  id              Int       @id @default(autoincrement())
  templateId      Int
  recipientUserId Int?
  recipientEmail  String?   @db.VarChar(255)
  recipientPhone  String?   @db.VarChar(30)
  channel         NotificationChannel
  status          NotificationStatus @default(PENDING)
  providerMsgId   String?   @db.VarChar(255)
  sentAt          DateTime?
  openedAt        DateTime?
  signedAt        DateTime?
  createdAt       DateTime  @default(now())

  @@index([templateId])
  @@index([recipientUserId])
  @@index([status])
  @@map("waiver_delivery_logs")
}

model WaiverAuditLog {
  id              Int       @id @default(autoincrement())
  templateId      Int?
  submissionId    Int?
  actorUserId     Int?
  action          String    @db.VarChar(50) // CREATED, PUBLISHED, ARCHIVED, SIGNED, REVOKED, RESENT, VIEWED
  details         Json      @default("{}")
  ipAddress       String?   @db.VarChar(50)
  createdAt       DateTime  @default(now())

  @@index([templateId])
  @@index([submissionId])
  @@index([actorUserId])
  @@map("waiver_audit_logs")
}

// ============================================================================
// WAIVER — Sign Requests, Recipients, Tags, Reviews
// ============================================================================

model WaiverSignRequest {
  id                      Int       @id @default(autoincrement())
  uuid                    String    @unique @db.VarChar(36)
  orgId                   Int?
  templateId              Int
  versionId               Int
  publishLinkId           Int?
  userId                  Int?
  externalName            String?   @db.VarChar(200)
  externalEmail           String?   @db.VarChar(255)
  externalPhone           String?   @db.VarChar(30)
  athleteProfileId        Int?
  bookingId               Int?
  eventRegistrationId     Int?
  sourceType              String?   @db.VarChar(50) // MANUAL, CAMPAIGN, AUTOMATION, EVENT, BOOKING, SEGMENT
  sourceId                String?   @db.VarChar(50)
  requestedViaChannel     String    @default("EMAIL") @db.VarChar(20) // EMAIL, WHATSAPP, PUSH, IN_APP, KIOSK, QR, MANUAL
  status                  String    @default("DRAFT") @db.VarChar(20) // DRAFT, QUEUED, SENT, OPENED, COMPLETED, EXPIRED, CANCELLED, FAILED
  sentAt                  DateTime?
  openedAt                DateTime?
  completedAt             DateTime?
  expiredAt               DateTime?
  reminderCount           Int       @default(0)
  lastReminderAt          DateTime?
  createdByUserId         Int?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  template                WaiverTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version                 WaiverTemplateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  publishLink             WaiverPublishLink?    @relation(fields: [publishLinkId], references: [id], onDelete: SetNull)
  user                    User?                 @relation("WaiverSignRequests", fields: [userId], references: [id], onDelete: SetNull)
  submissions             WaiverSubmission[]

  @@index([templateId])
  @@index([versionId])
  @@index([userId])
  @@index([status])
  @@index([externalEmail])
  @@map("waiver_sign_requests")
}

model WaiverRecipient {
  id                  Int       @id @default(autoincrement())
  orgId               Int?
  sourceType          String    @db.VarChar(50) // SEGMENT, EVENT, BOOKING, MANUAL
  sourceId            String?   @db.VarChar(50)
  userId              Int?
  email               String?   @db.VarChar(255)
  phone               String?   @db.VarChar(30)
  firstName           String?   @db.VarChar(100)
  lastName            String?   @db.VarChar(100)
  athleteProfileId    Int?
  eligibilityJson     Json?
  createdAt           DateTime  @default(now())

  @@index([userId])
  @@index([email])
  @@index([sourceType])
  @@map("waiver_recipients")
}

model WaiverTemplateTag {
  id              Int       @id @default(autoincrement())
  templateId      Int
  tag             String    @db.VarChar(50) // student, tandem, event, legal, medical, mandatory

  template        WaiverTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, tag])
  @@index([tag])
  @@map("waiver_template_tags")
}

model WaiverSubmissionReview {
  id              Int       @id @default(autoincrement())
  submissionId    Int
  reviewerUserId  Int
  status          String    @db.VarChar(20) // APPROVED, FLAGGED, REJECTED
  notes           String?   @db.Text
  reviewedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())

  submission      WaiverSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([reviewerUserId])
  @@map("waiver_submission_reviews")
}

// ─── Chat & Messaging ───────────────────────────────────────────────

enum ChatChannelType {
  DIRECT
  GROUP
  LOAD
}

model ChatChannel {
  id          Int              @id @default(autoincrement())
  name        String?          @db.VarChar(255)
  type        ChatChannelType  @default(GROUP)
  dropzoneId  Int
  avatarUrl   String?          @db.VarChar(500)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  dropzone    Dropzone         @relation("ChatChannels", fields: [dropzoneId], references: [id], onDelete: Cascade)
  members     ChatMember[]
  messages    ChatMessage[]

  @@index([dropzoneId])
  @@index([type])
  @@map("chat_channels")
}

model ChatMember {
  id         Int          @id @default(autoincrement())
  channelId  Int
  userId     Int
  role       String       @default("member") @db.VarChar(20)
  joinedAt   DateTime     @default(now())
  mutedUntil DateTime?
  lastReadAt DateTime?

  channel    ChatChannel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
  @@map("chat_members")
}

model ChatMessage {
  id         Int          @id @default(autoincrement())
  channelId  Int
  senderId   Int
  body       String       @db.Text
  replyToId  Int?
  createdAt  DateTime     @default(now())

  channel    ChatChannel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender     User         @relation("ChatMessagesSent", fields: [senderId], references: [id])
  replyTo    ChatMessage? @relation("ChatReplies", fields: [replyToId], references: [id])
  replies    ChatMessage[] @relation("ChatReplies")

  @@index([channelId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

// ============================================================================
// RIG MAINTENANCE MODULE
// Per SkyLara_Rig_Maintenance_Complete_Master_File.md — Sections 5-7
// ============================================================================

model Rig {
  id                        Int              @id @default(autoincrement())
  ownerUserId               Int
  dropzoneId                Int?
  rigName                   String           @db.VarChar(255)
  serialNumber              String?          @db.VarChar(100)
  rigType                   RigType          @default(SPORT)
  activeStatus              RigActiveStatus  @default(ACTIVE)
  maintenanceStatus         MaintenanceStatus @default(OK)
  totalJumps                Int              @default(0)
  isSharedRig               Boolean          @default(false)
  defaultManifestSelectable Boolean          @default(true)
  notes                     String?          @db.Text
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  // Relations
  owner              User                @relation("RigOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  dropzone           Dropzone?           @relation(fields: [dropzoneId], references: [id], onDelete: SetNull)
  container          RigContainer?
  mainCanopy         RigMainCanopy?
  reserve            RigReserve?
  aad                RigAAD?
  maintenanceRules   MaintenanceRule[]
  maintenanceEvents  MaintenanceEvent[]
  usageEvents        RigJumpUsageEvent[]
  groundingRecords   RigGroundingRecord[]
  slots              Slot[]

  @@index([ownerUserId])
  @@index([dropzoneId])
  @@index([activeStatus])
  @@index([maintenanceStatus])
  @@index([serialNumber])
  @@map("rigs")
}

model RigContainer {
  id              Int       @id @default(autoincrement())
  rigId           Int       @unique
  manufacturer    String?   @db.VarChar(100)
  model           String?   @db.VarChar(100)
  serialNumber    String?   @db.VarChar(100)
  manufactureDate DateTime?
  size            String?   @db.VarChar(50)
  serviceNotes    String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  rig             Rig       @relation(fields: [rigId], references: [id], onDelete: Cascade)

  @@map("rig_containers")
}

model RigMainCanopy {
  id                    Int       @id @default(autoincrement())
  rigId                 Int       @unique
  manufacturer          String?   @db.VarChar(100)
  model                 String?   @db.VarChar(100)
  size                  String?   @db.VarChar(50)
  serialNumber          String?   @db.VarChar(100)
  fabricType            String?   @db.VarChar(50)
  lineType              String?   @db.VarChar(50)
  installDate           DateTime?
  totalJumps            Int       @default(0)
  jumpsSinceInspection  Int       @default(0)
  jumpsSinceReline      Int       @default(0)
  lastInspectionDate    DateTime?
  lastRelineDate        DateTime?
  notes                 String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  rig                   Rig       @relation(fields: [rigId], references: [id], onDelete: Cascade)

  @@map("rig_main_canopies")
}

model RigReserve {
  id              Int       @id @default(autoincrement())
  rigId           Int       @unique
  manufacturer    String?   @db.VarChar(100)
  model           String?   @db.VarChar(100)
  serialNumber    String?   @db.VarChar(100)
  size            String?   @db.VarChar(50)
  installDate     DateTime?
  repackDate      DateTime?
  repackDueDate   DateTime?
  rides           Int       @default(0)
  inspectionNotes String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  rig             Rig       @relation(fields: [rigId], references: [id], onDelete: Cascade)

  @@map("rig_reserves")
}

model RigAAD {
  id                  Int       @id @default(autoincrement())
  rigId               Int       @unique
  manufacturer        String?   @db.VarChar(100)
  model               String?   @db.VarChar(100)
  serialNumber        String?   @db.VarChar(100)
  installDate         DateTime?
  lastServiceDate     DateTime?
  nextServiceDueDate  DateTime?
  batteryDueDate      DateTime?
  endOfLifeDate       DateTime?
  notes               String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  rig                 Rig       @relation(fields: [rigId], references: [id], onDelete: Cascade)

  @@map("rig_aads")
}

model MaintenanceRule {
  id               Int                 @id @default(autoincrement())
  rigId            Int?                // null = DZ-wide or global default rule
  dropzoneId       Int?                // scope for DZ-default rules
  componentType    RigComponentType
  ruleType         MaintenanceRuleType
  triggerByJumps   Int?                // e.g. 50 jumps
  triggerByDays    Int?                // e.g. 90 days
  dueSoonPercent   Int                 @default(80)  // % of trigger = DUE_SOON
  overduePercent   Int?                // % above trigger = OVERDUE (e.g. 120 = 20% over)
  hardStop         Boolean             @default(false) // true = GROUNDED when OVERDUE
  enabled          Boolean             @default(true)
  sourceType       RuleSourceType      @default(DZ_DEFAULT)
  appliesToRigType RigType?            // null = all rig types
  label            String?             @db.VarChar(255) // human-readable rule name
  notes            String?             @db.Text
  createdByUserId  Int
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  // Relations
  rig              Rig?                @relation(fields: [rigId], references: [id], onDelete: Cascade)
  dropzone         Dropzone?           @relation(fields: [dropzoneId], references: [id], onDelete: Cascade)
  createdBy        User                @relation("MaintenanceRuleCreator", fields: [createdByUserId], references: [id])

  @@index([rigId])
  @@index([dropzoneId])
  @@index([componentType])
  @@map("maintenance_rules")
}

model MaintenanceEvent {
  id                Int               @id @default(autoincrement())
  rigId             Int
  componentType     RigComponentType
  maintenanceType   String            @db.VarChar(100) // INSPECTION, SERVICE, REPACK, RELINE, etc.
  eventDate         DateTime
  result            MaintenanceResult
  findings          String?           @db.Text
  actionTaken       String?           @db.Text
  performedByUserId Int?
  performedByName   String?           @db.VarChar(255)
  signatureUrl      String?           @db.VarChar(500)
  attachmentUrls    Json?             // string[]
  resetCounterTypes Json?             // RigComponentType[] — which counters were reset
  countersBefore    Json?             // snapshot of counters before reset
  countersAfter     Json?             // snapshot of counters after reset
  notes             String?           @db.Text
  createdAt         DateTime          @default(now())

  // Relations
  rig               Rig               @relation(fields: [rigId], references: [id], onDelete: Cascade)
  performedBy       User?             @relation("MaintenancePerformer", fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([rigId])
  @@index([eventDate])
  @@index([componentType])
  @@map("maintenance_events")
}

model RigJumpUsageEvent {
  id                              Int      @id @default(autoincrement())
  rigId                           Int
  jumpId                          Int      // Slot.id that completed this jump
  loadId                          Int?
  userId                          Int
  completedAt                     DateTime
  rigTotalAfter                   Int
  mainTotalAfter                  Int?
  lineSetAfter                    Int?
  linkedMaintenanceStatusSnapshot Json?    // { rig: 'OK', main: 'DUE_SOON', ... }
  createdAt                       DateTime @default(now())

  // Relations
  rig                             Rig      @relation(fields: [rigId], references: [id], onDelete: Cascade)

  @@unique([rigId, jumpId]) // Idempotency: one rig + one jump = one usage event
  @@index([rigId])
  @@index([userId])
  @@index([completedAt])
  @@map("rig_jump_usage_events")
}

model RigGroundingRecord {
  id               Int       @id @default(autoincrement())
  rigId            Int
  componentType    RigComponentType
  reason           String    @db.Text
  policySource     String?   @db.VarChar(255)
  groundedByUserId Int
  groundedAt       DateTime  @default(now())
  clearedAt        DateTime?
  clearedByUserId  Int?
  clearanceNotes   String?   @db.Text
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())

  // Relations
  rig              Rig       @relation(fields: [rigId], references: [id], onDelete: Cascade)
  groundedBy       User      @relation("RigGroundedBy", fields: [groundedByUserId], references: [id])
  clearedBy        User?     @relation("RigClearedBy", fields: [clearedByUserId], references: [id])

  @@index([rigId])
  @@index([active])
  @@map("rig_grounding_records")
}

// ============================================================================
// SOCIAL, STORY & ACHIEVEMENTS (per gap spec §7.9, schema ref §9, §14)
// ============================================================================

enum PostVisibility {
  PUBLIC
  FOLLOWERS
  PRIVATE

  @@map("post_visibility")
}

enum MilestoneType {
  FIRST_JUMP
  LICENSE_EARNED
  JUMP_COUNT
  DISCIPLINE
  COMPETITION
  CUSTOM

  @@map("milestone_type")
}

model SocialPost {
  id              Int               @id @default(autoincrement())
  userId          Int
  dropzoneId      Int?
  loadId          Int?
  content         String            @db.Text
  visibility      PostVisibility    @default(PUBLIC)
  mediaIds        Json              @default("[]")  // MediaUpload IDs
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  comments        SocialComment[]
  reactions       SocialReaction[]

  @@index([userId])
  @@index([dropzoneId])
  @@index([createdAt])
  @@map("social_posts")
}

model SocialComment {
  id              Int       @id @default(autoincrement())
  postId          Int
  userId          Int
  content         String    @db.Text
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?

  post            SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@map("social_comments")
}

model SocialReaction {
  id              Int       @id @default(autoincrement())
  postId          Int
  userId          Int
  emoji           String    @db.VarChar(10)  // e.g. "fire", "heart", "thumbsup"
  createdAt       DateTime  @default(now())

  post            SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
  @@index([postId])
  @@map("social_reactions")
}

model Follow {
  id              Int       @id @default(autoincrement())
  followerId      Int
  followingId     Int
  createdAt       DateTime  @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Achievement {
  id              Int       @id @default(autoincrement())
  name            String    @unique @db.VarChar(100)
  description     String    @db.Text
  criteria        Json      @default("{}")  // e.g. { "type": "jump_count", "value": 100 }
  icon            String?   @db.VarChar(255)
  badgeColor      String?   @db.VarChar(9)
  displayOrder    Int       @default(0)
  createdAt       DateTime  @default(now())

  athletes        AthleteAchievement[]

  @@map("achievements")
}

model AthleteAchievement {
  id              Int       @id @default(autoincrement())
  userId          Int
  achievementId   Int
  earnedAt        DateTime  @default(now())
  context         Json?     // e.g. { "jumpNumber": 100, "dropzone": "Perris" }

  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("athlete_achievements")
}

model MediaUpload {
  id              Int       @id @default(autoincrement())
  userId          Int
  dropzoneId      Int?
  loadId          Int?
  fileUrl         String    @db.VarChar(500)
  thumbnailUrl    String?   @db.VarChar(500)
  mediaType       String    @db.VarChar(20)  // photo, video
  mimeType        String?   @db.VarChar(100)
  fileSizeBytes   Int?
  width           Int?
  height          Int?
  geoLat          Decimal?  @db.Decimal(10, 8)
  geoLng          Decimal?  @db.Decimal(11, 8)
  moderationStatus String   @default("APPROVED") @db.VarChar(20) // PENDING, APPROVED, REJECTED
  createdAt       DateTime  @default(now())

  tags            MediaTag[]

  @@index([userId])
  @@index([dropzoneId])
  @@index([loadId])
  @@map("media_uploads")
}

model MediaTag {
  id              Int       @id @default(autoincrement())
  mediaId         Int
  taggedUserId    Int
  createdAt       DateTime  @default(now())

  media           MediaUpload @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, taggedUserId])
  @@index([taggedUserId])
  @@map("media_tags")
}

model AthleteStory {
  id              Int       @id @default(autoincrement())
  userId          Int       @unique
  tagline         String?   @db.VarChar(255)
  narrative       String?   @db.Text
  disciplines     Json      @default("[]")     // string[]
  certifications  Json      @default("[]")     // string[]
  heroMediaId     Int?
  isPublic        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  milestones      AthleteMilestone[]

  @@map("athlete_stories")
}

model AthleteMilestone {
  id              Int           @id @default(autoincrement())
  storyId         Int
  type            MilestoneType
  title           String        @db.VarChar(255)
  description     String?       @db.Text
  achievedAt      DateTime
  jumpNumber      Int?
  mediaId         Int?
  createdAt       DateTime      @default(now())

  story           AthleteStory  @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@index([achievedAt])
  @@map("athlete_milestones")
}

model ActivityFeed {
  id              Int       @id @default(autoincrement())
  userId          Int
  dropzoneId      Int?
  eventType       String    @db.VarChar(50)  // JUMP, ACHIEVEMENT, POST, MILESTONE, FOLLOW
  entityType      String?   @db.VarChar(50)  // SocialPost, LogbookEntry, Achievement, etc.
  entityId        Int?
  summary         String    @db.VarChar(500)
  visibility      PostVisibility @default(PUBLIC)
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([dropzoneId])
  @@index([eventType])
  @@index([createdAt])
  @@map("activity_feed")
}

// ============================================================================
// SHOP / MARKETPLACE (per gap spec §7.9, schema ref §10)
// ============================================================================

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED_ORDER
  REFUNDED_ORDER

  @@map("order_status")
}

model ShopProduct {
  id              Int       @id @default(autoincrement())
  dropzoneId      Int
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  category        String    @db.VarChar(100)  // merch, media, service
  priceCents      Int
  currency        String    @default("USD") @db.VarChar(10)
  imageUrl        String?   @db.VarChar(500)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  inventory       ShopInventory[]
  orderItems      ShopOrderItem[]

  @@index([dropzoneId])
  @@index([category])
  @@map("shop_products")
}

model ShopInventory {
  id              Int       @id @default(autoincrement())
  productId       Int
  branchId        Int?      // null = all branches
  quantity        Int       @default(0)
  lowStockAlert   Int       @default(5)
  updatedAt       DateTime  @updatedAt

  product         ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId])
  @@map("shop_inventory")
}

model ShopOrder {
  id              Int         @id @default(autoincrement())
  uuid            String      @unique @db.VarChar(36)
  dropzoneId      Int
  userId          Int
  status          OrderStatus @default(PENDING)
  totalCents      Int
  currency        String      @default("USD") @db.VarChar(10)
  stripePaymentId String?     @db.VarChar(255)
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           ShopOrderItem[]

  @@index([dropzoneId])
  @@index([userId])
  @@index([status])
  @@map("shop_orders")
}

model ShopOrderItem {
  id              Int       @id @default(autoincrement())
  orderId         Int
  productId       Int
  quantity        Int
  unitPriceCents  Int
  createdAt       DateTime  @default(now())

  order           ShopOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         ShopProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@map("shop_order_items")
}

// ============================================================================
// LOCALIZATION (per gap spec §7.9, schema ref §13)
// ============================================================================

model Language {
  id              Int       @id @default(autoincrement())
  code            String    @unique @db.VarChar(10)  // BCP-47: en, es, fr, ar, etc.
  name            String    @db.VarChar(100)          // English, Spanish, etc.
  nativeName      String    @db.VarChar(100)          // English, Español, etc.
  isRtl           Boolean   @default(false)
  isActive        Boolean   @default(true)
  completeness    Int       @default(0)               // 0-100% translation coverage
  createdAt       DateTime  @default(now())

  translations    Translation[]

  @@map("languages")
}

model TranslationNamespace {
  id              Int       @id @default(autoincrement())
  name            String    @unique @db.VarChar(50)   // common, manifest, safety, etc.
  description     String?   @db.VarChar(255)
  createdAt       DateTime  @default(now())

  keys            TranslationKey[]

  @@map("translation_namespaces")
}

model TranslationKey {
  id              Int       @id @default(autoincrement())
  namespaceId     Int
  key             String    @db.VarChar(255)          // dot-path: manifest.load.status
  defaultValue    String    @db.Text                  // English default
  pluralSupport   Boolean   @default(false)
  description     String?   @db.VarChar(500)          // context for translators
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  namespace       TranslationNamespace @relation(fields: [namespaceId], references: [id], onDelete: Cascade)
  translations    Translation[]

  @@unique([namespaceId, key])
  @@index([namespaceId])
  @@map("translation_keys")
}

model Translation {
  id              Int       @id @default(autoincrement())
  keyId           Int
  languageId      Int
  value           String    @db.Text
  reviewStatus    String    @default("DRAFT") @db.VarChar(20) // DRAFT, REVIEWED, APPROVED
  reviewedById    Int?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  key             TranslationKey @relation(fields: [keyId], references: [id], onDelete: Cascade)
  language        Language       @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([keyId, languageId])
  @@index([languageId])
  @@map("translations")
}

model SupportedCurrency {
  id              Int       @id @default(autoincrement())
  code            String    @unique @db.VarChar(3)    // ISO 4217: USD, EUR, GBP, etc.
  name            String    @db.VarChar(100)
  symbol          String    @db.VarChar(5)            // $, €, £
  decimalPlaces   Int       @default(2)
  exchangeRate    Decimal   @default(1.0) @db.Decimal(12, 6) // rate to USD
  rateUpdatedAt   DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@map("supported_currencies")
}

model DzLocaleSettings {
  id              Int       @id @default(autoincrement())
  dropzoneId      Int       @unique
  languageCode    String    @default("en") @db.VarChar(10)
  currencyCode    String    @default("USD") @db.VarChar(3)
  weightUnit      String    @default("lbs") @db.VarChar(5)   // lbs, kg
  altitudeUnit    String    @default("ft") @db.VarChar(5)    // ft, m
  temperatureUnit String    @default("F") @db.VarChar(2)     // F, C
  dateFormat      String    @default("MM/DD/YYYY") @db.VarChar(20)
  timeFormat      String    @default("12h") @db.VarChar(5)   // 12h, 24h
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("dz_locale_settings")
}

// ============================================================================
// CAREERS & RECRUITMENT
// ============================================================================

enum JobPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  PAUSED
  CLOSED
  ARCHIVED

  @@map("job_post_status")
}

enum JobVisibilityType {
  INTERNAL_TARGETED
  INTERNAL_PROFESSIONAL_POOL
  ORGANIZATION_ONLY
  DROPZONE_ONLY
  INVITE_ONLY
  PUBLIC_LINK
  PUBLIC_MARKETPLACE

  @@map("job_visibility_type")
}

enum JobApplicationStage {
  APPLIED
  INITIAL_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  TECHNICAL_EVALUATION
  FINAL_REVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN

  @@map("job_application_stage")
}

enum JobInterviewType {
  VIDEO
  PHONE
  IN_PERSON
  TECHNICAL_JUMP
  TRIAL_DAY

  @@map("job_interview_type")
}

enum JobInterviewStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW

  @@map("job_interview_status")
}

model JobPost {
  id                    Int               @id @default(autoincrement())
  uuid                  String            @unique @db.VarChar(36)
  organizationId        Int?
  dropzoneId            Int?
  branchId              Int?
  createdBy             Int
  title                 String            @db.VarChar(255)
  slug                  String            @db.VarChar(150)
  roleCategory          String            @db.VarChar(50)  // TI, AFFI, COACH, PILOT, RIGGER, MANIFEST_STAFF, DZ_MANAGER, CAMERA, PACKER, OTHER
  employmentType        EmploymentType    @default(FULL_TIME)
  priority              String            @default("NORMAL") @db.VarChar(20) // LOW, NORMAL, HIGH, URGENT
  locationMode          String            @default("ON_SITE") @db.VarChar(20) // ON_SITE, REMOTE, HYBRID, TRAVEL
  city                  String?           @db.VarChar(100)
  country               String?           @db.VarChar(100)
  visibilityType        JobVisibilityType @default(INTERNAL_TARGETED)
  applicationMode       String            @default("INTERNAL") @db.VarChar(20) // INTERNAL, EXTERNAL_LINK, BOTH
  status                JobPostStatus     @default(DRAFT)
  description           String?           @db.Text
  responsibilitiesJson  Json              @default("[]")
  requirementsJson      Json              @default("[]")
  compensationJson      Json              @default("{}") // { min, max, currency, period, benefits[] }
  applicationQuestionsJson Json           @default("[]") // custom questions for applicants
  recruiterNote         String?           @db.Text        // internal note, never shown to candidates
  companyProfileSnapshot Json             @default("{}")  // DZ name, location, aircraft, vibe
  publishAt             DateTime?
  closeAt               DateTime?
  publicShareEnabled    Boolean           @default(false)
  externalShareUrl      String?           @db.VarChar(512)
  applicationsCount     Int               @default(0)
  viewsCount            Int               @default(0)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  creator               User              @relation("JobPostCreator", fields: [createdBy], references: [id])
  organization          Organization?     @relation("JobPostOrg", fields: [organizationId], references: [id], onDelete: SetNull)
  dropzone              Dropzone?         @relation("JobPostDz", fields: [dropzoneId], references: [id], onDelete: SetNull)
  targets               JobPostTarget[]
  audienceSnapshots     JobPostAudienceSnapshot[]
  applications          JobApplication[]

  @@unique([dropzoneId, slug])
  @@index([organizationId])
  @@index([dropzoneId])
  @@index([status])
  @@index([roleCategory])
  @@index([visibilityType])
  @@index([createdBy])
  @@map("job_posts")
}

model JobPostTarget {
  id              Int       @id @default(autoincrement())
  jobPostId       Int
  targetType      String    @db.VarChar(50) // ROLE, MIN_JUMPS, RATING, LICENSE_LEVEL, LOCATION, LANGUAGE, EXPERIENCE_YEARS, DISCIPLINE, VERIFIED_STATUS
  operator        String    @db.VarChar(20) // EQUALS, NOT_EQUALS, GTE, LTE, IN, NOT_IN, CONTAINS
  valueJson       Json                      // the target value(s)
  createdAt       DateTime  @default(now())

  jobPost         JobPost   @relation(fields: [jobPostId], references: [id], onDelete: Cascade)

  @@index([jobPostId])
  @@map("job_post_targets")
}

model JobPostAudienceSnapshot {
  id                    Int       @id @default(autoincrement())
  jobPostId             Int
  userId                Int
  matchScore            Int       @default(0) // 0-100
  matchTier             String    @db.VarChar(20) // EXACT, STRONG, PARTIAL, MANUAL_REVIEW
  reasonMatched         String?   @db.Text
  matchedAt             DateTime  @default(now())
  notifiedAt            DateTime?
  notificationChannels  Json      @default("[]") // ["EMAIL","PUSH","IN_APP"]

  jobPost               JobPost   @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  user                  User      @relation("JobAudienceUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobPostId, userId])
  @@index([jobPostId])
  @@index([userId])
  @@index([matchTier])
  @@map("job_post_audience_snapshots")
}

model JobApplication {
  id                    Int                 @id @default(autoincrement())
  uuid                  String              @unique @db.VarChar(36)
  jobPostId             Int
  applicantUserId       Int?                // null if external applicant
  applicantEmail        String              @db.VarChar(255)
  applicantName         String              @db.VarChar(200)
  applicantPhone        String?             @db.VarChar(30)
  currentStage          JobApplicationStage @default(APPLIED)
  status                String              @default("ACTIVE") @db.VarChar(20) // ACTIVE, ON_HOLD, ARCHIVED
  sourceType            String              @default("INTERNAL") @db.VarChar(20) // INTERNAL, PUBLIC_LINK, REFERRAL, MANUAL
  sourceRef             String?             @db.VarChar(255) // referrer userId or link ID
  profileSnapshotJson   Json                @default("{}") // name, nationality, location at time of application
  jumpsSnapshotJson     Json                @default("{}") // totalJumps, licenseLevel, disciplines
  ratingsSnapshotJson   Json                @default("{}") // instructorSkills, ratings at time of application
  coverLetter           String?             @db.Text
  resumeUrl             String?             @db.VarChar(512)
  availabilityDate      DateTime?
  relocationWilling     Boolean             @default(false)
  salaryExpectation     String?             @db.VarChar(100)
  submittedAt           DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  jobPost               JobPost             @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  applicant             User?               @relation("JobApplicant", fields: [applicantUserId], references: [id], onDelete: SetNull)
  answers               JobApplicationAnswer[]
  documents             JobApplicationDocument[]
  recruiterNotes        RecruiterNote[]
  stageEvents           ApplicationStageEvent[]
  interviews            InterviewSchedule[]

  @@unique([jobPostId, applicantEmail])
  @@index([jobPostId])
  @@index([applicantUserId])
  @@index([currentStage])
  @@index([status])
  @@map("job_applications")
}

model JobApplicationAnswer {
  id              Int             @id @default(autoincrement())
  applicationId   Int
  questionKey     String          @db.VarChar(100)
  answerValueJson Json            @default("{}")
  createdAt       DateTime        @default(now())

  application     JobApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, questionKey])
  @@index([applicationId])
  @@map("job_application_answers")
}

model JobApplicationDocument {
  id                    Int             @id @default(autoincrement())
  applicationId         Int
  documentType          String          @db.VarChar(50) // RESUME, LICENSE, RATING_CERT, MEDICAL, INSURANCE, REFERENCE, OTHER
  title                 String          @db.VarChar(255)
  fileUrl               String?         @db.VarChar(512)
  fileSize              Int?
  mimeType              String?         @db.VarChar(100)
  verificationStatus    String          @default("PENDING") @db.VarChar(20) // PENDING, VERIFIED, REJECTED
  reviewerNotes         String?         @db.Text
  reviewedBy            Int?
  reviewedAt            DateTime?
  uploadedAt            DateTime        @default(now())

  application           JobApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([verificationStatus])
  @@map("job_application_documents")
}

model RecruiterNote {
  id              Int             @id @default(autoincrement())
  applicationId   Int
  createdBy       Int
  noteType        String          @default("GENERAL") @db.VarChar(30) // GENERAL, SCREENING, FEEDBACK, DECISION, INTERNAL
  noteText        String          @db.Text
  visibilityScope String          @default("TEAM") @db.VarChar(20)   // PRIVATE, TEAM, ALL_REVIEWERS
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  application     JobApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  author          User            @relation("RecruiterNoteAuthor", fields: [createdBy], references: [id])

  @@index([applicationId])
  @@index([createdBy])
  @@map("recruiter_notes")
}

model ApplicationStageEvent {
  id              Int             @id @default(autoincrement())
  applicationId   Int
  fromStage       JobApplicationStage
  toStage         JobApplicationStage
  changedBy       Int
  reason          String?         @db.Text
  createdAt       DateTime        @default(now())

  application     JobApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([createdAt])
  @@map("application_stage_events")
}

model InterviewSchedule {
  id              Int                 @id @default(autoincrement())
  uuid            String              @unique @db.VarChar(36)
  applicationId   Int
  interviewType   JobInterviewType
  startsAt        DateTime
  endsAt          DateTime
  timezone        String              @default("UTC") @db.VarChar(50)
  locationOrLink  String?             @db.VarChar(512)
  scheduledBy     Int
  status          JobInterviewStatus  @default(SCHEDULED)
  notes           String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  application     JobApplication      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  scheduler       User                @relation("InterviewScheduler", fields: [scheduledBy], references: [id])
  feedback        InterviewFeedback[]

  @@index([applicationId])
  @@index([scheduledBy])
  @@index([startsAt])
  @@index([status])
  @@map("interview_schedules")
}

model InterviewFeedback {
  id              Int               @id @default(autoincrement())
  interviewId     Int
  reviewerUserId  Int
  score           Int?              // 1-5
  notes           String?           @db.Text
  recommendation  String?           @db.VarChar(30) // STRONG_HIRE, HIRE, HOLD, NO_HIRE, STRONG_NO_HIRE
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  interview       InterviewSchedule @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  reviewer        User              @relation("InterviewReviewer", fields: [reviewerUserId], references: [id])

  @@unique([interviewId, reviewerUserId])
  @@index([interviewId])
  @@index([reviewerUserId])
  @@map("interview_feedback")
}

// ============================================================================
// POLICY ENGINE — Configurable rules per org/DZ/branch (Expert Feedback §3)
// ============================================================================

model PolicyDefinition {
  id                Int             @id @default(autoincrement())
  category          PolicyCategory
  key               String          @db.VarChar(100)   // e.g. "manifest.maxWindSpeed"
  label             String          @db.VarChar(255)
  description       String?         @db.Text
  dataType          String          @db.VarChar(20)    // number, string, boolean, json
  defaultValue      Json                               // platform default
  validationSchema  Json?                              // optional constraints
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  values            PolicyValue[]
  auditLogs         PolicyAuditLog[]

  @@unique([category, key])
  @@index([category])
  @@map("policy_definitions")
}

model PolicyValue {
  id                Int             @id @default(autoincrement())
  definitionId      Int
  scope             PolicyScope
  organizationId    Int?
  dropzoneId        Int?
  branchId          Int?
  operationalDate   DateTime?       @db.Date           // for OPERATIONAL_DAY scope
  value             Json
  isActive          Boolean         @default(true)
  setById           Int
  reason            String?         @db.Text
  effectiveFrom     DateTime        @default(now())
  effectiveUntil    DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  definition        PolicyDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  auditLogs         PolicyAuditLog[]

  @@unique([definitionId, scope, organizationId, dropzoneId, branchId, operationalDate])
  @@index([definitionId, scope])
  @@index([dropzoneId])
  @@index([organizationId])
  @@map("policy_values")
}

model PolicyAuditLog {
  id                Int             @id @default(autoincrement())
  policyValueId     Int?
  definitionId      Int
  scope             PolicyScope
  scopeEntityId     Int?            // orgId, dzId, or branchId depending on scope
  previousValue     Json?
  newValue          Json?
  changedById       Int
  reason            String?         @db.Text
  ipAddress         String?         @db.VarChar(45)
  createdAt         DateTime        @default(now())

  policyValue       PolicyValue?     @relation(fields: [policyValueId], references: [id], onDelete: SetNull)
  definition        PolicyDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@index([changedById])
  @@index([createdAt])
  @@map("policy_audit_logs")
}

// ============================================================================
// VERIFICATION MODEL — Universal verification state (Expert Feedback §4)
// ============================================================================

model Verification {
  id                  Int                @id @default(autoincrement())
  entityType          String             @db.VarChar(50)  // LICENSE, GEAR_ITEM, PROGRESSION, etc.
  entityId            Int
  dropzoneId          Int
  status              VerificationState  @default(SELF_DECLARED)
  verifiedById        Int?
  verificationSource  String?            @db.VarChar(100)
  evidenceNote        String?            @db.Text
  evidenceUrl         String?            @db.VarChar(512)
  expiresAt           DateTime?
  reviewIntervalDays  Int?               // auto-expire after N days
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  history             VerificationHistory[]

  @@unique([entityType, entityId])
  @@index([dropzoneId])
  @@index([status])
  @@index([expiresAt])
  @@map("verifications")
}

model VerificationHistory {
  id                Int                @id @default(autoincrement())
  verificationId    Int
  entityType        String             @db.VarChar(50)
  entityId          Int
  fromStatus        VerificationState?
  toStatus          VerificationState
  changedById       Int
  reason            String?            @db.Text
  evidenceUrl       String?            @db.VarChar(512)
  createdAt         DateTime           @default(now())

  verification      Verification       @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("verification_history")
}

// ============================================================================
// OPS MESSAGE TEMPLATES — Private manifest-to-athlete messaging (Expert §6)
// ============================================================================

model OpsMessageTemplate {
  id              Int       @id @default(autoincrement())
  dropzoneId      Int?      // null = platform-wide template
  key             String    @db.VarChar(100)  // e.g. "move_load", "add_money"
  title           String    @db.VarChar(255)
  body            String    @db.Text
  channels        Json      @default("[\"IN_APP\",\"PUSH\"]")  // NotificationChannel[]
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([dropzoneId, key])
  @@index([dropzoneId])
  @@map("ops_message_templates")
}

