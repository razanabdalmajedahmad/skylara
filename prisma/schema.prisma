// ============================================================================
// GIFT CARDS — Issue, redeem, expire
// ============================================================================

model GiftCard {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @db.VarChar(36)
  code            String    @unique @db.VarChar(50) // e.g. SKYLARA-2026-ABCD1234
  dropzoneId      Int
  issuedById      Int       // Staff who issued
  recipientName   String    @db.VarChar(255)
  recipientEmail  String?   @db.VarChar(255)
  amountCents     Int       // Original value in cents
  balanceCents    Int       // Remaining balance
  currency        String    @default("AED") @db.VarChar(10)
  status          GiftCardStatus @default(ACTIVE)
  message         String?   @db.Text
  redeemedById    Int?      // User who redeemed
  redeemedAt      DateTime?
  expiresAt       DateTime?
