// ============================================================================
// PROPERTY RENTALS & ACCOMMODATION — Per Property_Rentals_Accommodation_Spec
// ============================================================================

enum RentalListingType {
  HOTEL_ROOM
  APARTMENT
  VILLA
  ROOM_SHARE
  BUNKHOUSE
  HOSTEL_BED
  RV_HOOKUP
  CAMPSITE
  MONTHLY_FURNISHED
  EVENT_PACKAGE
  DZ_MANAGED
}

enum RentalHostType {
  INDIVIDUAL
  BUSINESS
  DROPZONE
  PARTNER
}

enum RentalBookingStatus {
  PENDING
  HELD
  CONFIRMED
  DECLINED
  CANCELLED
  EXPIRED
  COMPLETED
}

enum RentalBookingMode {
  INSTANT_BOOK
  REQUEST_TO_BOOK
  HOLD_THEN_CONFIRM
  EXTERNAL_REDIRECT
  PARTNER_BOOKING
}

enum RentalVisibility {
  DRAFT
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum RentalComplianceStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
}

enum PetPolicy {
  ALLOWED
  NOT_ALLOWED
  BY_REQUEST
}

enum CancellationPolicy {
  FLEXIBLE
  MODERATE
  STRICT
}

model RentalListing {
  id                   Int                    @id @default(autoincrement())
  dropzoneId           Int
  hostId               Int
  title                String                 @db.VarChar(255)
  slug                 String                 @unique @db.VarChar(255)
  description          String?                @db.Text
  listingType          RentalListingType
  hostType             RentalHostType
  address              String                 @db.VarChar(500)
  city                 String?                @db.VarChar(100)
  country              String?                @db.VarChar(100)
  latitude             Decimal                @db.Decimal(10, 7)
  longitude            Decimal                @db.Decimal(10, 7)
  distanceToDropzone   Float                  // km
  sleepingCapacity     Int                    @default(1)
  bathrooms            Int                    @default(1)
  petPolicy            PetPolicy              @default(NOT_ALLOWED)
  cancellationPolicy   CancellationPolicy     @default(MODERATE)
  visibility           RentalVisibility       @default(DRAFT)
  complianceStatus     RentalComplianceStatus @default(DRAFT)
  bookingMode          RentalBookingMode      @default(REQUEST_TO_BOOK)
  basePrice            Decimal                @db.Decimal(10, 2)
  currency             String                 @default("USD") @db.VarChar(3)
  weeklyDiscount       Float?                 // percentage
  monthlyDiscount      Float?                 // percentage
  amenities            Json?                  // Array of amenity keys
  skydiverAmenities    Json?                  // { gearStorage, rigLocker, packingSpace, shuttle, etc. }
  heroImageUrl         String?                @db.VarChar(500)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  // Relations
  host                 RentalHost             @relation(fields: [hostId], references: [id])
  photos               RentalPhoto[]
  availability         RentalAvailabilityBlock[]
  bookings             RentalBooking[]
  reviews              RentalReview[]
  savedBy              RentalSavedProperty[]
  compliance           RentalComplianceRecord[]

  @@index([dropzoneId, visibility])
  @@index([city])
  @@index([latitude, longitude])
  @@index([listingType])
  @@index([basePrice])
  @@map("rental_listings")
}

model RentalHost {
  id                   Int                    @id @default(autoincrement())
  userId               Int
  displayName          String                 @db.VarChar(255)
  bio                  String?                @db.Text
  phoneNumber          String?                @db.VarChar(30)
  hostType             RentalHostType         @default(INDIVIDUAL)
  stripeConnectId      String?                @db.VarChar(255)
  payoutEnabled        Boolean                @default(false)
  verifiedAt           DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  // Relations
  listings             RentalListing[]

  @@unique([userId])
  @@map("rental_hosts")
}

model RentalPhoto {
  id           Int                     @id @default(autoincrement())
  listingId    Int
  url          String                  @db.VarChar(500)
  caption      String?                 @db.VarChar(255)
  sortOrder    Int                     @default(0)
  createdAt    DateTime                @default(now())

  // Relations
  listing      RentalListing           @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("rental_photos")
}

model RentalAvailabilityBlock {
  id           Int                     @id @default(autoincrement())
  listingId    Int
  startDate    DateTime                @db.Date
  endDate      DateTime                @db.Date
  status       String                  @db.VarChar(30) // AVAILABLE, BLOCKED, BOOKED
  priceOverride Decimal?               @db.Decimal(10, 2)
  note         String?                 @db.VarChar(255)
  createdAt    DateTime                @default(now())

  // Relations
  listing      RentalListing           @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, startDate, endDate])
  @@map("rental_availability_blocks")
}

model RentalBooking {
  id                   Int                    @id @default(autoincrement())
  uuid                 String                 @unique @default(uuid()) @db.VarChar(36)
  listingId            Int
  guestId              Int
  checkInDate          DateTime               @db.Date
  checkOutDate         DateTime               @db.Date
  numberOfGuests       Int                    @default(1)
  numberOfNights       Int
  totalPrice           Decimal                @db.Decimal(10, 2)
  bookingFee           Decimal                @default(0) @db.Decimal(10, 2)
  currency             String                 @default("USD") @db.VarChar(3)
  status               RentalBookingStatus    @default(PENDING)
  bookingMode          RentalBookingMode
  paymentStatus        String                 @default("PENDING") @db.VarChar(30) // PENDING, AUTHORIZED, CHARGED, REFUNDED
  paymentIntentId      String?                @db.VarChar(255)
  hostPayoutStatus     String                 @default("PENDING") @db.VarChar(30) // PENDING, HELD, RELEASED, FAILED
  cancellationReason   String?                @db.Text
  cancellationBy       String?                @db.VarChar(30) // GUEST, HOST, PLATFORM
  specialRequests      String?                @db.Text
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  // Relations
  listing              RentalListing          @relation(fields: [listingId], references: [id])

  @@index([listingId, status])
  @@index([guestId])
  @@index([checkInDate])
  @@map("rental_bookings")
}

model RentalReview {
  id           Int                     @id @default(autoincrement())
  listingId    Int
  userId       Int
  bookingId    Int?
  rating       Int                     // 1-5
  title        String?                 @db.VarChar(255)
  body         String?                 @db.Text
  hostResponse String?                 @db.Text
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  // Relations
  listing      RentalListing           @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([userId])
  @@map("rental_reviews")
}

model RentalSavedProperty {
  id           Int                     @id @default(autoincrement())
  userId       Int
  listingId    Int
  savedAt      DateTime                @default(now())

  // Relations
  listing      RentalListing           @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("rental_saved_properties")
}

model RentalComplianceRecord {
  id              Int                  @id @default(autoincrement())
  listingId       Int
  dropzoneId      Int
  approvalState   RentalComplianceStatus @default(DRAFT)
  permitMetadata  Json?
  complianceNotes String?              @db.Text
  documentUrls    Json?                // Array of document file URLs
  verifiedAt      DateTime?
  verifiedById    Int?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Relations
  listing         RentalListing        @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([dropzoneId, approvalState])
  @@map("rental_compliance_records")
}

// ============================================================================
// WEBSITE & PUBLIC PORTAL
// ============================================================================

model WebsiteSettings {
  id              Int      @id @default(autoincrement())
  dropzoneId      Int      @unique
  companyName     String?  @db.VarChar(255)
  tagline         String?  @db.VarChar(500)
  description     String?  @db.Text
  primaryColor    String   @default("#1A4F8A") @db.VarChar(7)
  secondaryColor  String   @default("#0EA5E9") @db.VarChar(7)
  accentColor     String   @default("#10B981") @db.VarChar(7)
  logoUrl         String?  @db.VarChar(500)
  faviconUrl      String?  @db.VarChar(500)
  heroImageUrl    String?  @db.VarChar(500)
  ga4MeasurementId String? @db.VarChar(50)
  gtmContainerId  String?  @db.VarChar(50)
  metaPixelId     String?  @db.VarChar(50)
  customDomain    String?  @db.VarChar(255)
  isPublished     Boolean  @default(false)
  publicManifestEnabled Boolean @default(false)
  accountPortalEnabled Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  pages           WebsitePage[]
  @@map("website_settings")
}

model WebsitePage {
  id              Int      @id @default(autoincrement())
  settingsId      Int
  pageType        String   @db.VarChar(50) // HOMEPAGE, ABOUT, SERVICES, TANDEM, AFF, WEATHER, EVENTS, JOBS, STAYS, COURSES, FAQ, CONTACT, CUSTOM
  title           String   @db.VarChar(255)
  slug            String   @db.VarChar(255)
  metaTitle       String?  @db.VarChar(255)
  metaDescription String?  @db.VarChar(500)
  ogImage         String?  @db.VarChar(500)
  contentBlocks   Json?    // Array of content block definitions
  isPublished     Boolean  @default(false)
  sortOrder       Int      @default(0)
  showInNav       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  settings        WebsiteSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@unique([settingsId, slug])
  @@index([settingsId, isPublished])
  @@map("website_pages")
