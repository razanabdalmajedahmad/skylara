  dropzoneId      Int
  userId          Int
  dayOfWeek       Int             // 0=Sun through 6=Sat
  startTime       String          @db.VarChar(5)
  endTime         String          @db.VarChar(5)
  employmentType  EmploymentType  @default(FULL_TIME)
  createdAt       DateTime        @default(now())
