// ============================================================================
// GLOBAL PLATFORM HIERARCHY — Phase 1
// ============================================================================

enum FacilityCategory {
  AVIATION
  HOTEL
  APARTMENT
  BUNKHOUSE
  CAFE
  SHOP
  MIXED

  @@map("facility_category")
}

enum FacilityStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ONBOARDING
  ARCHIVED

  @@map("facility_status")
}

enum EntitlementState {
  PROVISIONED
  ACTIVE
  FROZEN
  HELD
  SUSPENDED
  DEPRECATED
  MIGRATED

  @@map("entitlement_state")
}

model Region {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @default(uuid()) @db.VarChar(36)
  name            String    @db.VarChar(255)
  slug            String    @unique @db.VarChar(100)
  countryCode     String    @db.VarChar(3)    // ISO 3166-1 alpha-2/3
  subdivisionCode String?   @db.VarChar(10)   // ISO 3166-2 (state/province)
  timezone        String    @default("UTC") @db.VarChar(50)
  currency        String    @default("USD") @db.VarChar(10)
  status          String    @default("active") @db.VarChar(50)
  parentRegionId  Int?                        // Self-referencing for sub-regions
  metadata        Json?                       // Extensible key-value
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  parentRegion    Region?   @relation("RegionHierarchy", fields: [parentRegionId], references: [id], onDelete: SetNull)
  childRegions    Region[]  @relation("RegionHierarchy")
  facilities      Facility[]
  auditLogs       AuditLog[] @relation("AuditRegion")

  @@index([countryCode])
  @@index([parentRegionId])
  @@map("regions")
}

model Facility {
  id              Int              @id @default(autoincrement())
  uuid            String           @unique @default(uuid()) @db.VarChar(36)
  organizationId  Int
  regionId        Int?
  dropzoneId      Int?             @unique // FK to existing Dropzone for AVIATION type
  name            String           @db.VarChar(255)
  slug            String           @db.VarChar(100)
  category        FacilityCategory
  status          FacilityStatus   @default(ACTIVE)
  description     String?          @db.Text
  latitude        Decimal?         @db.Decimal(10, 8)
  longitude       Decimal?         @db.Decimal(11, 8)
  timezone        String           @default("UTC") @db.VarChar(50)
  currency        String           @default("USD") @db.VarChar(10)
  address         String?          @db.VarChar(500)
  city            String?          @db.VarChar(100)
  state           String?          @db.VarChar(100)
  postalCode      String?          @db.VarChar(20)
  countryCode     String?          @db.VarChar(3)
  phone           String?          @db.VarChar(30)
  email           String?          @db.VarChar(255)
  website         String?          @db.VarChar(500)
  capacity        Int?              // Max occupancy/users depending on type
  operatingHours  Json?             // { mon: { open: "08:00", close: "17:00" }, ... }
  metadata        Json?             // Extensible key-value per category
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  region          Region?          @relation(fields: [regionId], references: [id], onDelete: SetNull)
  dropzone        Dropzone?        @relation(fields: [dropzoneId], references: [id], onDelete: SetNull)
  facilityMeta    FacilityMeta[]
  entitlements    EntitlementGrant[]
  auditLogs       AuditLog[]       @relation("AuditFacility")
  impersonationSessions ImpersonationSession[]
  reviews         FacilityReview[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([regionId])
  @@index([category])
  @@index([status])
  @@map("facilities")
}

model FacilityMeta {
  id              Int       @id @default(autoincrement())
  facilityId      Int
  key             String    @db.VarChar(100)
  value           String    @db.Text
  valueType       String    @default("string") @db.VarChar(20) // string, number, boolean, json
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  facility        Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([facilityId, key])
  @@index([facilityId])
  @@map("facility_meta")
}

model EntitlementGrant {
  id              Int              @id @default(autoincrement())
  uuid            String           @unique @default(uuid()) @db.VarChar(36)
  featureKey      String           @db.VarChar(100)   // e.g. "manifest", "hospitality", "retail"
  state           EntitlementState @default(PROVISIONED)
  scope           String           @db.VarChar(50)    // "platform", "region", "organization", "facility"
  scopeId         Int?                                // ID of the scoped entity
  facilityId      Int?
  grantedBy       Int?                                // User who granted
  grantedAt       DateTime         @default(now())
  activatedAt     DateTime?
  frozenAt        DateTime?
  suspendedAt     DateTime?
  expiresAt       DateTime?
  reason          String?          @db.Text
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  facility        Facility?        @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([featureKey, scope, scopeId])
  @@index([facilityId])
  @@index([state])
  @@map("entitlement_grants")
}

// ============================================================================
// PHASE 2: IMPERSONATION, CROSS-FACILITY WALLET, REPUTATION ENGINE
// ============================================================================

model ImpersonationSession {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @default(uuid()) @db.VarChar(36)
  actorUserId     Int                        // Admin performing impersonation
  targetUserId    Int                        // User being impersonated
  targetFacilityId Int?                      // Optional facility context
  reason          String    @db.Text
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  active          Boolean   @default(true)
  ipAddress       String?   @db.VarChar(45)
  userAgent       String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  actorUser       User      @relation("ImpersonationActor", fields: [actorUserId], references: [id])
  targetUser      User      @relation("ImpersonationTarget", fields: [targetUserId], references: [id])
  targetFacility  Facility? @relation(fields: [targetFacilityId], references: [id])

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([active])
  @@map("impersonation_sessions")
}

model WalletTransfer {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @default(uuid()) @db.VarChar(36)
  sourceWalletId  Int
  targetWalletId  Int
  amount          Int                        // cents
  currency        String    @default("USD") @db.VarChar(10)
  reason          String?   @db.Text
  status          String    @default("PENDING") @db.VarChar(20) // PENDING, COMPLETED, FAILED, REVERSED
  initiatedBy     Int
  approvedBy      Int?
  completedAt     DateTime?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  sourceWallet    Wallet    @relation("TransferSource", fields: [sourceWalletId], references: [id])
  targetWallet    Wallet    @relation("TransferTarget", fields: [targetWalletId], references: [id])
  initiator       User      @relation("TransferInitiator", fields: [initiatedBy], references: [id])
  approver        User?     @relation("TransferApprover", fields: [approvedBy], references: [id])

  @@index([sourceWalletId])
  @@index([targetWalletId])
  @@index([status])
  @@map("wallet_transfers")
}

model FacilityReview {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @default(uuid()) @db.VarChar(36)
  facilityId      Int
  userId          Int
  rating          Int                        // 1-5 stars
  title           String?   @db.VarChar(255)
  body            String?   @db.Text
  category        String?   @db.VarChar(50)  // safety, service, value, amenities, overall
  status          String    @default("PUBLISHED") @db.VarChar(20) // PENDING, PUBLISHED, HIDDEN, FLAGGED
  helpfulCount    Int       @default(0)
  facilityResponse String?  @db.Text
  respondedAt     DateTime?
  respondedBy     Int?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  facility        Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user            User      @relation("FacilityReviewAuthor", fields: [userId], references: [id])
  responder       User?     @relation("FacilityReviewResponder", fields: [respondedBy], references: [id])

  @@unique([facilityId, userId])
  @@index([facilityId])
  @@index([userId])
  @@index([rating])
  @@map("facility_reviews")
}

model ReputationScore {
  id              Int       @id @default(autoincrement())
  entityType      String    @db.VarChar(50)  // "facility", "user", "organization"
  entityId        Int
  overallScore    Decimal   @db.Decimal(3, 2) // 0.00 - 5.00
  totalReviews    Int       @default(0)
  safetyScore     Decimal?  @db.Decimal(3, 2)
  serviceScore    Decimal?  @db.Decimal(3, 2)
  valueScore      Decimal?  @db.Decimal(3, 2)
  trustLevel      String    @default("STANDARD") @db.VarChar(20) // NEW, STANDARD, TRUSTED, VERIFIED, ELITE
  lastCalculatedAt DateTime @default(now())
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([entityType, entityId])
  @@index([overallScore])
  @@index([trustLevel])
  @@map("reputation_scores")
}

// ============================================================================
// VENUE & COMMERCIAL — Integrated Venue / Advertising (Phase 1: spaces + bookings)
// ============================================================================

enum VenueSpaceType {
  HANGAR
  CLASSROOM
  MEETING_ROOM
  OUTDOOR_PAD
  VIP_AREA
  BRIEFING_ROOM
  PACKING_AREA
  RETAIL_CORNER
  SPONSOR_BOOTH
  TEMP_ACTIVATION
  HOSPITALITY
  VIEWING_AREA
  OTHER
}

enum VenueSpaceUseMode {
  OPERATIONAL_ONLY
  CUSTOMER_RENTABLE
  ADVERTISER_RENTABLE
  MIXED_USE
}

enum VenueSpaceStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum VenueAvailabilityKind {
  BLOCKED
}

enum VenueBookingStatus {
  DRAFT_INQUIRY
  AWAITING_APPROVAL
  APPROVED
  QUOTED
  CONFIRMED
  PAID_PARTIAL
  CANCELLED
  COMPLETED
  REJECTED
}

model VenueSpace {
  id               Int               @id @default(autoincrement())
  uuid             String            @unique @default(uuid()) @db.VarChar(36)
  dropzoneId       Int
  name             String            @db.VarChar(255)
  slug             String            @db.VarChar(120)
  description      String?           @db.Text
  spaceType        VenueSpaceType    @default(OTHER)
  useMode          VenueSpaceUseMode @default(MIXED_USE)
  capacity         Int?
  indoor           Boolean           @default(true)
  basePriceCents   Int?
  currency         String            @default("USD") @db.VarChar(10)
  status           VenueSpaceStatus  @default(DRAFT)
  createdByUserId  Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  dropzone         Dropzone          @relation(fields: [dropzoneId], references: [id], onDelete: Cascade)
  createdBy        User?             @relation("VenueSpaceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  availability     VenueSpaceAvailability[]
  bookings         VenueBooking[]

  @@unique([dropzoneId, slug])
  @@index([dropzoneId])
  @@index([status])
  @@map("venue_spaces")
}

model VenueSpaceAvailability {
  id            Int                   @id @default(autoincrement())
  venueSpaceId  Int
  startAt       DateTime
  endAt         DateTime
  kind          VenueAvailabilityKind @default(BLOCKED)
  note          String?               @db.VarChar(500)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  venueSpace    VenueSpace            @relation(fields: [venueSpaceId], references: [id], onDelete: Cascade)

  @@index([venueSpaceId])
  @@index([startAt, endAt])
  @@map("venue_space_availability")
}

model VenueBooking {
  id                 Int                 @id @default(autoincrement())
  uuid               String              @unique @default(uuid()) @db.VarChar(36)
  dropzoneId         Int
  venueSpaceId       Int
  requesterUserId    Int?
  title              String              @db.VarChar(255)
  description        String?             @db.Text
  organizerName      String?             @db.VarChar(200)
  organizerEmail     String?             @db.VarChar(255)
  organizerPhone     String?             @db.VarChar(40)
  startAt            DateTime
  endAt              DateTime
  status             VenueBookingStatus  @default(DRAFT_INQUIRY)
  quotedAmountCents  Int?
  currency           String              @default("USD") @db.VarChar(10)
  internalNotes      String?             @db.Text
  reviewedByUserId   Int?
  reviewedAt         DateTime?
  createdByUserId    Int?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  dropzone           Dropzone            @relation(fields: [dropzoneId], references: [id], onDelete: Cascade)
  venueSpace         VenueSpace          @relation(fields: [venueSpaceId], references: [id], onDelete: Restrict)
  requester          User?               @relation("VenueBookingRequester", fields: [requesterUserId], references: [id], onDelete: SetNull)
  reviewedBy         User?               @relation("VenueBookingReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  createdBy          User?               @relation("VenueBookingCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([dropzoneId])
  @@index([venueSpaceId])
  @@index([status])
  @@index([startAt, endAt])
  @@map("venue_bookings")
}
