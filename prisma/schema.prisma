model User {
  id                    Int       @id @default(autoincrement())
  uuid                  String    @unique @db.VarChar(36)
  email                 String    @unique @db.VarChar(255)
  phone                 String?   @db.VarChar(20)
  passwordHash          String    @db.VarChar(255)
  firstName             String    @db.VarChar(100)
  lastName              String    @db.VarChar(100)
  status                UserStatus @default(ACTIVE)
  emailVerifiedAt       DateTime?
  lastLoginAt           DateTime?
  preferredLanguage     String    @default("en") @db.VarChar(10)
  importBatchId         String?   @db.VarChar(100) // migration batch tag for rollback
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  // Relations
  profile               UserProfile?
  userRoles             UserRole[]
  slots                 Slot[]
  instructorSlots       Slot[] @relation("InstructorSlots")
  cameraSlots           Slot[] @relation("CameraSlots")
  groupsAsCaptan        Group[] @relation("GroupCaptain")
  groupMembers          GroupMember[] @relation("GroupMembers")
  qrTokens              QrToken[]
  waiverSignatures      WaiverSignature[]
  emergencyProfile      EmergencyProfile?
  gearsOwned            GearItem[] @relation("GearOwner")
  gearChecks            GearCheck[] @relation("CheckedByUser")
  wallets               Wallet[]
  incidents             Incident[] @relation("ReportedBy")
  assignedIncidents     Incident[] @relation("AssignedTo")
  notifications         Notification[]
  auditLogs             AuditLog[]
  syncOutbox            SyncOutbox[]
  organizationOwner     Organization? @relation("OrganizationOwner")
  loadsAsPilot          Load[] @relation("LoadPilot")
  ideasSubmitted        IdeaNote[] @relation("ideasSubmitted")
  ideasReviewed         IdeaNote[] @relation("ideasReviewed")
  tourProgress          UserTourProgress[]
  refreshTokens         RefreshToken[]
  passwordResetTokens   PasswordResetToken[]
  passkeys              Passkey[]
  oauthAccounts         OAuthAccount[]
  mfaDevices            MfaDevice[]
  onboardingSessions    OnboardingSession[]
  stripeAccounts        StripeAccount[]
  paymentIntents        PaymentIntent[]
  assistantConversations AssistantConversation[]
  assistantUsageDaily     AssistantUsageDaily[]
  assistantMetricEvents   AssistantMetricEvent[]
  reportDashboards      ReportDashboard[]
  athlete               Athlete?
  licenses              License[]
  currencyChecks        CurrencyCheck[]
  logbookEntries        LogbookEntry[]
  cgChecksPerformed     CgCheck[] @relation("CgPerformedBy")
  waitlistEntries       WaitlistEntry[]
  loadNotes             LoadNote[]
  affInstructorRecords  AffRecord[] @relation("AffInstructor")
  instructorSkills      InstructorSkill[]
  instructorAvailability InstructorAvailability[]
  assignmentsAsInstructor InstructorAssignment[] @relation("AssignedInstructor")
  assignmentsAsStudent  InstructorAssignment[] @relation("AssignedStudent")
  bookings              Booking[]
  bookingRequestsAsInstructor BookingRequest[] @relation("BookingReqInstructor")
  gearRentalsAsUser     GearRental[] @relation("GearRentalUser")
  gearRentalsAsAssigner GearRental[] @relation("GearRentalAssigner")
  riskAssessments       RiskAssessment[] @relation("RiskAssessor")
  overrideLogs          OverrideLog[] @relation("OverrideUser")
  coachSessions         CoachingSession[] @relation("CoachSessions")
  coachingParticipations CoachingParticipant[] @relation("CoachingParticipants")
  boogiesCreated        Boogie[] @relation("BoogieCreator")
  boogieRegistrations   BoogieRegistration[] @relation("BoogieRegUser")
  boogieGroupInstructor BoogieGroup[] @relation("BoogieGroupInstructor")
  boogieStaffAssignments BoogieStaffAssignment[] @relation("BoogieStaffUser")
  boogieStaffAssigned BoogieStaffAssignment[] @relation("BoogieStaffAssigner")
  boogieAnnouncementsCreated BoogieAnnouncement[] @relation("BoogieAnnouncementCreator")
  coachApplications   CoachApplication[] @relation("CoachAppUser")
  coachAppReviews     CoachApplication[] @relation("CoachAppReviewer")
  dzAppContacts       DropzoneApplication[] @relation("DzAppContact")
  dzAppReviews        DropzoneApplication[] @relation("DzAppReviewer")
  staffSchedules        StaffSchedule[] @relation("StaffSchedUser")
  weatherHoldsActivated WeatherHold[] @relation("WeatherHoldActivator")
  medicalDeclarations   MedicalDeclaration[]
  documents             Document[]
  assignedTasks         Task[] @relation("TaskAssignee")
  createdTasks          Task[] @relation("TaskCreator")
  // Onboarding center relations
  onboardingApplications    OnboardingApplication[] @relation("OnboardingApps")
  onboardingAppReviews      OnboardingApplication[] @relation("OnboardingAppReviewer")
  pushDevices               PushDevice[]
  whatsappConsents          WhatsAppConsent[]
  communicationPreference   CommunicationPreference?
  notificationEvents        NotificationEvent[] @relation("NotificationEvents")
  assistantRecommendations  AssistantRecommendation[] @relation("AssistantRecs")
  waiverSubmissions         WaiverSubmission[] @relation("WaiverSubmissions")
  waiverSignRequests        WaiverSignRequest[] @relation("WaiverSignRequests")
  waiverTemplatesCreated    WaiverTemplate[] @relation("WaiverTemplateCreator")
  chatMemberships           ChatMember[]
  chatMessagesSent          ChatMessage[] @relation("ChatMessagesSent")
  // Rig Maintenance relations
  rigsOwned                 Rig[] @relation("RigOwner")
  maintenanceRulesCreated   MaintenanceRule[] @relation("MaintenanceRuleCreator")
  maintenanceEventsPerformed MaintenanceEvent[] @relation("MaintenancePerformer")
  rigsGroundedBy            RigGroundingRecord[] @relation("RigGroundedBy")
  rigsClearedBy             RigGroundingRecord[] @relation("RigClearedBy")
  // Careers & Recruitment relations
