}

model BookingRequest {
  id                  Int                   @id @default(autoincrement())
  bookingId           Int
  instructorId        Int?
  status              BookingRequestStatus  @default(PENDING)
  responseDeadline    DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  booking             Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  instructor          User?                 @relation("BookingReqInstructor", fields: [instructorId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([instructorId])
  @@map("booking_requests")
}

// ============================================================================
// EVENT OUTBOX — Transactional reliability for financial events
