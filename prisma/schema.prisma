  landingAreaScore Int      // 0-100
  hazardScore     Int       // 0-100
  compositeScore  Int       // weighted composite 0-100
  riskLevel       RiskLevel
  notes           String?   @db.Text
  validUntil      DateTime
  supersededById  Int?
  createdAt       DateTime  @default(now())

  dropzone        Dropzone  @relation("RiskDz", fields: [dropzoneId], references: [id], onDelete: Cascade)
  assessedBy      User      @relation("RiskAssessor", fields: [assessedById], references: [id], onDelete: Restrict)

  @@index([dropzoneId])
  @@index([createdAt])
  @@map("risk_assessments")
}

model IncidentInvolvedParty {
  id              Int       @id @default(autoincrement())
  incidentId      Int
  userId          Int?
  roleInIncident  String    @db.VarChar(100)
  gearItemId      Int?
  notes           String?   @db.Text

  incident        Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("incident_involved_parties")
}

model WeatherData {
