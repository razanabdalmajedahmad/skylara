{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "SkyLara API (Fastify)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:api"],
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "SkyLara Web (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=@skylara/web"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Prisma Studio",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["prisma", "studio", "--schema=prisma/schema.prisma"],
      "port": 5555
    },
    {
      "name": "SkyLara Mobile (Expo Web)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=@skylara/mobile", "--", "--web", "--clear"],
      "port": 8081,
      "autoPort": true
    }
  ]
}
